{# NovaKur Base section component: promo_banners #}
{% set banners = banners|default([]) %}

{% if banners is empty %}
  {% set banners = [
    {
      title: 'New Arrivals',
      subtitle: 'Fresh styles just landed',
      href: '#',
      image: '',
      cta_text: 'Shop now',
      bg_class: 'bg-gradient-to-br from-primary/80 to-blue-800'
    },
    {
      title: 'Sale — Up to 50% off',
      subtitle: 'Limited time offers',
      href: '#',
      image: '',
      cta_text: 'View deals',
      bg_class: 'bg-gradient-to-br from-slate-700 to-slate-900'
    }
  ] %}
{% endif %}

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  {% for banner in banners %}
    <a href="{{ banner.href|default('#') }}" class="relative rounded-2xl overflow-hidden min-h-[200px] group block {{ banner.bg_class|default('bg-slate-800') }}">
      {% if banner.image|default('') %}
        <img src="{{ banner.image }}" alt="{{ banner.title|default('') }}" class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
      {% endif %}
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      <div class="absolute bottom-0 left-0 p-6 z-10">
        <h3 class="text-white font-black text-xl mb-1">{{ banner.title|default('') }}</h3>
        <p class="text-white/80 text-sm mb-3">{{ banner.subtitle|default('') }}</p>
        <span class="inline-block bg-white text-slate-900 rounded-full px-5 py-2 text-xs font-bold hover:bg-slate-100 transition-all">
          {{ banner.cta_text|default('Shop now') }}
        </span>
      </div>
    </a>
  {% endfor %}
</div>
