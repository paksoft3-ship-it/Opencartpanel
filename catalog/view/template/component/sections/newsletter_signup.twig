{# NovaKur Base section component: newsletter_signup #}
{% set heading = heading|default('Stay in the loop') %}
{% set subheading = subheading|default('Get exclusive deals, new arrivals and more — delivered to your inbox.') %}
{% set action = action|default('#') %}
{% set button_text = button_text|default('Subscribe') %}

<section class="bg-gradient-to-br from-primary to-blue-700 py-16 px-4">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-black text-white mb-3">{{ heading }}</h2>
    <p class="text-white/80 text-sm mb-8">{{ subheading }}</p>
    <form action="{{ action }}" method="post" class="flex flex-col sm:flex-row gap-3">
      <input
        type="email"
        name="email"
        placeholder="Enter your email address"
        required
        class="flex-1 rounded-xl px-4 py-3 text-sm outline-none bg-white text-slate-900 placeholder-slate-400 focus:ring-2 focus:ring-white/30"
      >
      <button type="submit" class="bg-white text-primary rounded-xl px-6 py-3 font-bold hover:bg-slate-50 transition-all shrink-0 text-sm cursor-pointer">
        {{ button_text }}
      </button>
    </form>
  </div>
</section>
