{{ header }}

<style>
:root {
  --nk-bg-main: #0f172a;
  --nk-bg-surface: #101c22;
  --nk-bg-card: #162130;
  --nk-accent: #0da2e7;
  --nk-text-main: #e2e8f0;
  --nk-text-muted: #64748b;
  --nk-border: rgba(226, 232, 240, 0.1);
  --nk-radius: 2px;
  --nk-font: 'Inter', sans-serif;
}
body { background-color: var(--nk-bg-main); color: var(--nk-text-main); font-family: var(--nk-font); margin: 0; -webkit-font-smoothing: antialiased; }
*, *::before, *::after { box-sizing: border-box; }
a { text-decoration: none; color: inherit; transition: color 0.2s; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }
input { font-family: inherit; outline: none; }
.nk-elec-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* BREADCRUMB BAR */
.nk-elec-breadcrumb-bar { background-color: var(--nk-bg-surface); padding: 12px 0; border-bottom: 1px solid var(--nk-border); }
.nk-elec-breadcrumb-inner { display: flex; justify-content: space-between; align-items: center; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
.nk-elec-breadcrumbs { display: flex; gap: 8px; color: var(--nk-text-muted); }
.nk-elec-breadcrumbs a:hover { color: var(--nk-accent); }
.nk-elec-breadcrumbs span { color: var(--nk-text-main); }
.nk-elec-product-count { color: var(--nk-text-muted); }

/* MAIN LAYOUT */
.nk-elec-layout { display: grid; grid-template-columns: 260px 1fr; gap: 32px; padding: 40px 0; }

/* SIDEBAR */
.nk-elec-sidebar { position: sticky; top: 80px; height: max-content; }
.nk-elec-filter-section { border-bottom: 1px solid var(--nk-border); padding-bottom: 24px; margin-bottom: 24px; }
.nk-elec-filter-label { font-size: 11px; text-transform: uppercase; color: var(--nk-text-muted); font-weight: 700; letter-spacing: 0.1em; margin-bottom: 16px; display: block; }
.nk-elec-filter-title { font-size: 13px; font-weight: 700; text-transform: uppercase; margin-bottom: 12px; color: var(--nk-text-main); }
.nk-elec-price-inputs { display: flex; gap: 8px; align-items: center; margin-bottom: 12px; }
.nk-elec-price-inputs input { width: 100%; background: var(--nk-bg-card); border: 1px solid var(--nk-border); color: var(--nk-text-main); padding: 8px 12px; border-radius: var(--nk-radius); font-size: 13px; }
.nk-elec-price-inputs input:focus { border-color: var(--nk-accent); }
.nk-elec-btn-apply { background: var(--nk-accent); color: #fff; width: 100%; padding: 10px; font-weight: 700; text-transform: uppercase; font-size: 12px; letter-spacing: 0.05em; border-radius: var(--nk-radius); cursor: pointer; transition: background 0.2s; }
.nk-elec-btn-apply:hover { background: #0b8ecb; }
.nk-elec-checkbox-list { display: flex; flex-direction: column; gap: 10px; }
.nk-elec-checkbox { display: flex; align-items: center; gap: 10px; font-size: 13px; cursor: pointer; }
.nk-elec-checkbox input { appearance: none; width: 16px; height: 16px; border: 1px solid var(--nk-text-muted); border-radius: var(--nk-radius); background: transparent; cursor: pointer; position: relative; flex-shrink: 0; }
.nk-elec-checkbox input:checked { background: var(--nk-accent); border-color: var(--nk-accent); }
.nk-elec-checkbox input:checked::after { content: ''; position: absolute; left: 4px; top: 1px; width: 4px; height: 8px; border: solid white; border-width: 0 2px 2px 0; transform: rotate(45deg); }
.nk-elec-pills { display: flex; flex-wrap: wrap; gap: 8px; }
.nk-elec-pill { background: var(--nk-bg-card); border: 1px solid var(--nk-border); color: var(--nk-text-main); padding: 6px 12px; font-size: 12px; font-weight: 600; border-radius: var(--nk-radius); cursor: pointer; transition: all 0.2s; }
.nk-elec-pill:hover { border-color: var(--nk-text-muted); }
.nk-elec-pill.is-active { background: var(--nk-accent); border-color: var(--nk-accent); color: #fff; }
.nk-elec-toggle-row { display: flex; justify-content: space-between; align-items: center; }
.nk-elec-toggle { position: relative; width: 36px; height: 20px; background: var(--nk-bg-card); border-radius: 10px; cursor: pointer; border: 1px solid var(--nk-border); transition: background 0.2s; }
.nk-elec-toggle::after { content: ''; position: absolute; top: 2px; left: 2px; width: 14px; height: 14px; background: var(--nk-text-muted); border-radius: 50%; transition: transform 0.2s, background 0.2s; }
.nk-elec-toggle.is-active { background: var(--nk-accent); border-color: var(--nk-accent); }
.nk-elec-toggle.is-active::after { transform: translateX(16px); background: #fff; }
.nk-elec-clear { color: var(--nk-text-muted); font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block; margin-top: 16px; }
.nk-elec-clear:hover { color: var(--nk-accent); }

/* PRODUCT GRID */
.nk-elec-grid-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
.nk-elec-grid-title { margin: 0; font-size: 22px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.02em; }
.nk-elec-sort select { background: var(--nk-bg-surface); color: var(--nk-text-main); border: 1px solid var(--nk-border); padding: 8px 12px; border-radius: var(--nk-radius); font-size: 13px; outline: none; }
.nk-elec-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.nk-elec-cat-card { background: var(--nk-bg-card); border: 1px solid var(--nk-border); border-radius: var(--nk-radius); overflow: hidden; display: flex; flex-direction: column; transition: transform 0.2s, border-color 0.2s; position: relative; }
.nk-elec-cat-card:hover { border-color: var(--nk-accent); transform: translateY(-4px); }
.nk-elec-card-img { aspect-ratio: 4 / 3; background: linear-gradient(135deg, var(--nk-bg-surface), #1e293b); display: flex; align-items: center; justify-content: center; position: relative; padding: 24px; }
.nk-elec-card-img img { max-width: 100%; max-height: 100%; object-fit: contain; }
.nk-elec-badge { position: absolute; top: 12px; left: 12px; padding: 4px 8px; font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; border-radius: var(--nk-radius); color: #fff; z-index: 2; }
.nk-elec-badge--hot { background: #ef4444; }
.nk-elec-badge--new { background: var(--nk-accent); }
.nk-elec-card-body { padding: 20px; display: flex; flex-direction: column; flex: 1; }
.nk-elec-card-title { font-size: 14px; font-weight: 600; margin: 0 0 12px 0; color: var(--nk-text-main); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.4; height: 38px; }
.nk-elec-specs { display: flex; align-items: center; gap: 6px; color: var(--nk-text-muted); font-size: 12px; margin-bottom: 12px; }
.nk-elec-specs svg { width: 14px; height: 14px; flex-shrink: 0; }
.nk-elec-stock { font-size: 12px; font-weight: 600; margin-bottom: 16px; }
.nk-elec-stock--in { color: #22c55e; }
.nk-elec-stock--low { color: #f59e0b; }
.nk-elec-price-row { margin-top: auto; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
.nk-elec-price { font-size: 18px; font-weight: 800; color: var(--nk-accent); }
.nk-elec-price-old { font-size: 13px; text-decoration: line-through; color: var(--nk-text-muted); }
.nk-elec-card-footer { display: flex; gap: 8px; }
.nk-elec-btn-cart { flex: 1; background: var(--nk-bg-surface); border: 1px solid var(--nk-accent); color: var(--nk-accent); font-weight: 700; text-transform: uppercase; font-size: 12px; letter-spacing: 0.05em; padding: 10px; border-radius: var(--nk-radius); transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; cursor: pointer; }
.nk-elec-btn-cart:hover { background: var(--nk-accent); color: #fff; }
.nk-elec-btn-wish { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; background: var(--nk-bg-surface); border: 1px solid var(--nk-border); color: var(--nk-text-muted); border-radius: var(--nk-radius); transition: all 0.2s; cursor: pointer; }
.nk-elec-btn-wish:hover { color: #ef4444; border-color: #ef4444; }
.nk-elec-btn-wish svg { width: 18px; height: 18px; }

/* PAGINATION */
.nk-elec-pagination { margin-top: 40px; display: flex; justify-content: center; }
.nk-elec-pagination ul { list-style: none; padding: 0; margin: 0; display: flex; gap: 8px; }
.nk-elec-pagination li a, .nk-elec-pagination li span { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: var(--nk-bg-surface); border: 1px solid var(--nk-border); color: var(--nk-text-main); font-size: 13px; font-weight: 600; border-radius: var(--nk-radius); transition: all 0.2s; }
.nk-elec-pagination li.active span { background: var(--nk-accent); border-color: var(--nk-accent); color: #fff; }
.nk-elec-pagination li a:hover { border-color: var(--nk-accent); color: var(--nk-accent); }

[data-anim="fade-up"] { opacity: 0; transform: translateY(20px); transition: opacity 0.4s ease-out, transform 0.4s ease-out; }
[data-anim="fade-up"].is-visible { opacity: 1; transform: translateY(0); }

@media (max-width: 1024px) {
  .nk-elec-layout { grid-template-columns: 1fr; }
  .nk-elec-sidebar { position: static; display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .nk-elec-filter-section { border: none; padding: 0; margin: 0; }
}
@media (max-width: 768px) {
  .nk-elec-sidebar { grid-template-columns: 1fr; }
  .nk-elec-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .nk-elec-grid { grid-template-columns: 1fr; }
}
</style>

<!-- BREADCRUMB BAR -->
<div class="nk-elec-breadcrumb-bar">
  <div class="nk-elec-container">
    <div class="nk-elec-breadcrumb-inner">
      <div class="nk-elec-breadcrumbs">
        <a href="{{ home|default('#') }}">Home</a>
        <span>&rsaquo;</span>
        <span>{{ heading_title|default('Products') }}</span>
      </div>
      <span class="nk-elec-product-count">
        {% if products %}{{ products|length }} Products Found{% endif %}
      </span>
    </div>
  </div>
</div>

<!-- MAIN CONTENT -->
<div class="nk-elec-container">
  <div class="nk-elec-layout">

    <!-- SIDEBAR -->
    <aside class="nk-elec-sidebar">
      <span class="nk-elec-filter-label">Filter By</span>

      <div class="nk-elec-filter-section">
        <div class="nk-elec-filter-title">Price Range</div>
        <div class="nk-elec-price-inputs">
          <input type="number" placeholder="Min $" min="0">
          <input type="number" placeholder="Max $" min="0">
        </div>
        <button class="nk-elec-btn-apply">Apply</button>
      </div>

      <div class="nk-elec-filter-section">
        <div class="nk-elec-filter-title">Brand</div>
        <div class="nk-elec-checkbox-list">
          <label class="nk-elec-checkbox"><input type="checkbox"> Apple</label>
          <label class="nk-elec-checkbox"><input type="checkbox"> ASUS</label>
          <label class="nk-elec-checkbox"><input type="checkbox"> Dell</label>
          <label class="nk-elec-checkbox"><input type="checkbox"> Lenovo</label>
          <label class="nk-elec-checkbox"><input type="checkbox" checked> MSI</label>
        </div>
      </div>

      <div class="nk-elec-filter-section">
        <div class="nk-elec-filter-title">RAM</div>
        <div class="nk-elec-pills">
          <button class="nk-elec-pill">8GB</button>
          <button class="nk-elec-pill is-active">16GB</button>
          <button class="nk-elec-pill">32GB</button>
          <button class="nk-elec-pill">64GB</button>
        </div>
      </div>

      <div class="nk-elec-filter-section" style="border:none;padding:0;">
        <div class="nk-elec-toggle-row">
          <div class="nk-elec-filter-title" style="margin:0;">In Stock Only</div>
          <div class="nk-elec-toggle is-active" onclick="this.classList.toggle('is-active')"></div>
        </div>
      </div>

      <a href="#" class="nk-elec-clear">Clear All Filters</a>
    </aside>

    <!-- PRODUCT GRID -->
    <main>
      <div class="nk-elec-grid-header">
        <h1 class="nk-elec-grid-title">{{ heading_title|default('All Products') }}</h1>
        <div class="nk-elec-sort">
          <select>
            <option>Sort By: Featured</option>
            <option>Price: Low to High</option>
            <option>Price: High to Low</option>
            <option>Newest Arrivals</option>
          </select>
        </div>
      </div>

      <div class="nk-elec-grid">
        {% if products and products|length > 0 %}
          {% for product in products %}
            <div class="nk-elec-cat-card" data-anim="fade-up">
              <a href="{{ product.href }}" class="nk-elec-card-img">
                {% if product.special %}
                  <span class="nk-elec-badge nk-elec-badge--hot">HOT DEAL</span>
                {% elseif loop.index is odd %}
                  <span class="nk-elec-badge nk-elec-badge--new">NEW</span>
                {% endif %}
                <img src="{{ product.thumb }}" alt="{{ product.name }}">
              </a>
              <div class="nk-elec-card-body">
                <a href="{{ product.href }}" class="nk-elec-card-title">{{ product.name }}</a>
                {% if loop.index % 3 == 0 %}
                  <div class="nk-elec-stock nk-elec-stock--low">⚠ Low Stock</div>
                {% else %}
                  <div class="nk-elec-stock nk-elec-stock--in">● In Stock</div>
                {% endif %}
                <div class="nk-elec-price-row">
                  {% if product.special %}
                    <span class="nk-elec-price">{{ product.special }}</span>
                    <span class="nk-elec-price-old">{{ product.price }}</span>
                  {% else %}
                    <span class="nk-elec-price">{{ product.price }}</span>
                  {% endif %}
                </div>
                <div class="nk-elec-card-footer">
                  <button class="nk-elec-btn-cart" onclick="cart.add('{{ product.product_id }}');">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    Add to Cart
                  </button>
                  <button class="nk-elec-btn-wish" onclick="wishlist.add('{{ product.product_id }}');">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                  </button>
                </div>
              </div>
            </div>
          {% endfor %}
        {% else %}
          {% set demo_names = [
            "ProBook 450 G9 15.6\" FHD | i7-1255U | 16GB | 512GB SSD",
            "ThinkPad X1 Carbon Gen 10 | i7-1260P | 32GB | 1TB SSD",
            "ROG Zephyrus G14 | Ryzen 9 6900HS | 16GB | RTX 3060",
            "MacBook Pro 14\" M2 Pro | 10-core CPU | 16-core GPU",
            "XPS 15 9520 | i7-12700H | 16GB | RTX 3050 Ti",
            "Legion 5 Pro 16\" | Ryzen 7 6800H | RTX 3070"
          ] %}
          {% for i in 1..6 %}
            <div class="nk-elec-cat-card" data-anim="fade-up">
              <a href="#" class="nk-elec-card-img">
                {% if i == 1 or i == 4 %}<span class="nk-elec-badge nk-elec-badge--hot">HOT</span>{% elseif i == 2 %}<span class="nk-elec-badge nk-elec-badge--new">NEW</span>{% endif %}
              </a>
              <div class="nk-elec-card-body">
                <a href="#" class="nk-elec-card-title">{{ demo_names[i-1] }}</a>
                {% if i == 3 %}<div class="nk-elec-stock nk-elec-stock--low">⚠ Low Stock</div>{% else %}<div class="nk-elec-stock nk-elec-stock--in">● In Stock</div>{% endif %}
                <div class="nk-elec-price-row">
                  {% if i == 1 or i == 4 %}
                    <span class="nk-elec-price">$1,299.00</span>
                    <span class="nk-elec-price-old">$1,499.00</span>
                  {% else %}
                    <span class="nk-elec-price">$1,399.00</span>
                  {% endif %}
                </div>
                <div class="nk-elec-card-footer">
                  <button class="nk-elec-btn-cart">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    Add to Cart
                  </button>
                  <button class="nk-elec-btn-wish">
                    <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                  </button>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>

      {% if pagination %}
        <div class="nk-elec-pagination">{{ pagination|raw }}</div>
      {% else %}
        <div class="nk-elec-pagination">
          <ul>
            <li class="active"><span>1</span></li>
            <li><a href="#">2</a></li>
            <li><a href="#">3</a></li>
            <li><a href="#">&rsaquo;</a></li>
          </ul>
        </div>
      {% endif %}
    </main>

  </div>
</div>

<script>
document.querySelectorAll('[data-anim="fade-up"]').forEach(function(el) {
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
  }, { threshold: 0.1 });
  io.observe(el);
});
</script>

{{ footer }}
