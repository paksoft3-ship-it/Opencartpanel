{{ header }}

<main class="nkb-main">
  {% include 'catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}

  <header class="nkb-section" style="padding-bottom: 40px;">
    <span class="nkb-hero__eyebrow">Beauty Collection</span>
    <h1 class="nkb-section__title" style="font-size: 52px; margin-top: 12px;">{{ heading_title }}</h1>
    {% if description %}
      <div class="nkb-hero p" style="max-width: 720px; font-size: 16px; margin-top: 16px; padding: 0;">{{ description }}</div>
    {% endif %}
  </header>

  {% if before_image is defined and before_image %}
  <section class="nkb-section" style="padding-top: 0;">
    {% include 'extension/novakur/catalog/view/template/component/commerce/before_after_slider.twig' %}
  </section>
  {% endif %}

  <section class="nkb-section" style="padding-top: 0;">
    <div class="nkb-featured__grid" style="margin-top: 0;">
      {% for product in products %}
        {% include 'extension/novakur/catalog/view/template/component/commerce/product_card_beauty.twig' with { product: product } only %}
      {% else %}
        <div style="grid-column: 1/-1; text-align: center; padding: 80px 0; background: var(--nkb-surface); border-radius: 24px;">
          <span class="material-symbols-outlined" style="font-size: 48px; color: var(--nkb-outline); margin-bottom: 24px;">search_off</span>
          <h3 class="nkb-section__title">No products found</h3>
          <p class="nkb-hero p" style="margin: 12px auto;">Try adjusting your collection filters or browse the full range.</p>
          <a href="{{ continue }}" class="nkb-btn-primary" style="margin-top: 24px; display: inline-block; text-decoration: none;">Browse Everything</a>
        </div>
      {% endfor %}
    </div>

    {% if pagination %}
      <div style="margin-top: 64px; display: flex; justify-content: center;">
        {{ pagination }}
      </div>
    {% endif %}
  </section>
</main>

{{ footer }}
