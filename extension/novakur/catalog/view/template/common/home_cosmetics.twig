{{ header }}

<style>
.nkb-main { max-width: 1280px; margin: 0 auto; padding: 0 32px; }
.nkb-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; padding: 64px 0; }
.nkb-hero__content { display: flex; flex-direction: column; gap: 32px; }
.nkb-hero__eyebrow { font-size: 12px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--nkb-secondary); font-weight: 600; }
.nkb-hero h1 { font-family: var(--nkb-font-headline); font-size: 72px; font-style: italic; line-height: 1.1; margin: 0; color: var(--nkb-on-surface); }
.nkb-hero p { font-size: 18px; line-height: 1.6; color: rgba(27,28,27,0.7); max-width: 440px; margin: 0; font-weight: 300; }
.nkb-hero__visual { position: relative; }
.nkb-hero__image { aspect-ratio: 4/5; border-radius: 16px; overflow: hidden; box-shadow: 0 40px 80px rgba(45,41,38,0.1); }
.nkb-hero__image img { width: 100%; height: 100%; object-fit: cover; }
.nkb-hero__detail { position: absolute; bottom: -32px; left: -32px; width: 192px; aspect-ratio: 1; border-radius: 16px; border: 8px solid var(--nkb-bg); overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.1); display: none; }
@media (min-width: 768px) { .nkb-hero__detail { display: block; } }

.nkb-section { padding: 96px 0; }
.nkb-section__header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; }
.nkb-section__title { font-family: var(--nkb-font-headline); font-size: 32px; font-style: italic; margin: 0; }
.nkb-cat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
@media (min-width: 768px) { .nkb-cat-grid { grid-template-columns: repeat(4, 1fr); } }
.nkb-cat-card { cursor: pointer; }
.nkb-cat-card__img { aspect-ratio: 1; border-radius: 16px; overflow: hidden; margin-bottom: 16px; background: var(--nkb-surface); }
.nkb-cat-card__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s; }
.nkb-cat-card:hover img { transform: scale(1.05); }
.nkb-cat-card__eyebrow { font-size: 11px; text-transform: uppercase; letter-spacing: 0.2em; color: var(--nkb-outline); display: block; margin-bottom: 4px; }
.nkb-cat-card h3 { font-family: var(--nkb-font-headline); font-size: 20px; margin: 0; }

.nkb-featured { text-align: center; }
.nkb-featured__grid { display: grid; grid-template-columns: 1fr; gap: 32px; margin-top: 48px; }
@media (min-width: 640px) { .nkb-featured__grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .nkb-featured__grid { grid-template-columns: repeat(4, 1fr); } }

.nkb-ritual { background: rgba(123, 84, 85, 0.05); border-radius: 24px; padding: 80px 48px; display: grid; grid-template-columns: 1fr; gap: 64px; align-items: center; }
@media (min-width: 1024px) { .nkb-ritual { grid-template-columns: 1fr 1fr; } }
.nkb-ritual__visual { display: flex; gap: 16px; }
.nkb-ritual__img { flex: 1; display: flex; flex-direction: column; gap: 16px; align-items: center; }
.nkb-ritual__img-wrap { aspect-ratio: 3/4; border-radius: 16px; overflow: hidden; width: 100%; }
.nkb-ritual__img-wrap img { width: 100%; height: 100%; object-fit: cover; }
.nkb-ritual__label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; font-weight: 600; }
.nkb-ritual__img:last-child { margin-top: 48px; }
.nkb-ritual__img:last-child .nkb-ritual__img-wrap { box-shadow: 0 32px 64px rgba(0,0,0,0.1); }

.nkb-ingredient-strip { background: #2d2926; color: #f5f3f1; border-radius: 24px; padding: 64px; position: relative; overflow: hidden; }
.nkb-ingredient-strip h2 { font-family: var(--nkb-font-headline); font-size: 32px; font-style: italic; margin: 0 0 32px 0; position: relative; z-index: 2; }
.nkb-ingredients { display: flex; flex-wrap: wrap; gap: 48px; position: relative; z-index: 2; }
.nkb-ingredient h5 { color: #e3c199; font-size: 14px; font-weight: 500; margin: 0 0 4px 0; }
.nkb-ingredient p { font-size: 12px; color: #80756b; margin: 0; }
.nkb-ingredient-strip::after { content: ''; position: absolute; right: 0; top: 0; width: 30%; height: 100%; background: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAdSkhiuKUFc6c3PJPT5lXOd-T0ae5l1WXZxQrMgVcsU3TgtREGg-UQh9cOPARK73FLgPn6jSwCGO_JF_j5ek1a5FHnXqsXnWvUV3Fp1WRY119XtukxYe6R7o3OCsuS4i5rWHTGAVAirV6WBZu_0iSYRm4roqynoco_1oJgsnUM3xFTIelC7809gSWzepCTtA77NZUEx8U3nIj3HssBe9JA9g-eIV-IUQ-Mb5WYksAmedKUEXAWq7gnh6hIYpVf4q66UkSFxApWcQw') right/cover no-repeat; opacity: 0.1; }

.nkb-newsletter { text-align: center; max-width: 640px; margin: 0 auto; }
.nkb-newsletter h2 { font-family: var(--nkb-font-headline); font-size: 32px; font-style: italic; margin-bottom: 16px; }
.nkb-newsletter p { color: var(--nkb-outline); font-size: 14px; margin-bottom: 40px; }
.nkb-form { display: flex; flex-direction: column; gap: 16px; }
@media (min-width: 640px) { .nkb-form { flex-direction: row; } }
.nkb-btn-primary { background: var(--nkb-primary); color: #fff; border: none; padding: 16px 40px; border-radius: 999px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600; cursor: pointer; transition: opacity 0.3s; }
.nkb-btn-primary:hover { opacity: 0.9; }
.nkb-btn-outline { border: 1px solid rgba(116,90,57,0.3); color: var(--nkb-primary); background: transparent; padding: 16px 40px; border-radius: 999px; font-size: 12px; text-transform: uppercase; letter-spacing: 0.15em; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; }
.nkb-input { flex: 1; background: #fff; border: 1px solid rgba(128,117,107,0.2); border-radius: 999px; padding: 16px 24px; font-size: 14px; outline: none; }
.nkb-input:focus { border-color: var(--nkb-primary); }

.nkb-pdp-card { position: relative; text-align: left; }
.nkb-pdp-card__img { aspect-ratio: 4/5; background: #fff; border-radius: 12px; overflow: hidden; margin-bottom: 20px; position: relative; }
.nkb-pdp-card__img img { width: 100%; height: 100%; object-fit: contain; padding: 24px; transition: transform 0.5s; }
.nkb-pdp-card:hover .nkb-pdp-card__img img { transform: scale(1.05); }
.nkb-pdp-card__btn { position: absolute; bottom: 16px; left: 16px; right: 16px; background: rgba(251,249,247,0.9); backdrop-filter: blur(8px); padding: 12px; border-radius: 999px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; border: none; cursor: pointer; opacity: 0; transform: translateY(10px); transition: all 0.3s; }
.nkb-pdp-card:hover .nkb-pdp-card__btn { opacity: 1; transform: translateY(0); }
.nkb-pdp-card h4 { font-size: 14px; font-weight: 500; margin: 0 0 4px 0; display: flex; justify-content: space-between; }
.nkb-pdp-card p { font-size: 12px; color: var(--nkb-outline); margin: 0; font-weight: 300; }
</style>

