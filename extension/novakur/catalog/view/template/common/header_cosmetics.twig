<style>
  :root {
    --nkb-primary: #745a39;
    --nkb-secondary: #7b5455;
    --nkb-bg: #fbf9f7;
    --nkb-surface: #efedec;
    --nkb-on-surface: #1b1c1b;
    --nkb-outline: #80756b;
    --nkb-font-headline: 'Cormorant Garamond', serif;
    --nkb-font-body: 'Inter', sans-serif;
  }
  .nkb-promo-bar { background: #eae8e6; py: 8px; text-align: center; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: #4e453c; padding: 8px 0; }
  .nkb-header { sticky: top; background: var(--nkb-bg); box-shadow: 0 20px 40px rgba(45,41,38,0.04); z-index: 50; }
  .nkb-header__main { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 24px 32px; }
  .nkb-header__brand { font-family: var(--nkb-font-headline); font-size: 28px; font-style: italic; color: #2d2926; text-decoration: none; }
  .nkb-header__actions { display: flex; justify-content: flex-end; gap: 24px; color: var(--nkb-primary); }
  .nkb-header__nav { border-top: 1px solid rgba(128,117,107,0.1); padding: 16px 0; }
  .nkb-header__nav ul { display: flex; justify-content: center; gap: 40px; list-style: none; margin: 0; padding: 0; }
  .nkb-header__nav a { font-size: 12px; text-transform: uppercase; letter-spacing: 0.1em; color: #2d2926; text-decoration: none; transition: color 0.3s; }
  .nkb-header__nav a:hover { color: var(--nkb-primary); }
  .nkb-header__nav a.is-active { border-bottom: 1px solid #c9a882; padding-bottom: 4px; color: var(--nkb-primary); }
</style>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

<div class="nkb-promo-bar">Complimentary shipping on orders over $150</div>

<header class="nkb-header">
  <div class="nkb-header__main">
    <div class="nkb-header__search">
      <span class="material-symbols-outlined" style="color: var(--nkb-primary); cursor: pointer;">search</span>
    </div>
    <a href="{{ home }}" class="nkb-header__brand">{{ name }}</a>
    <div class="nkb-header__actions">
      <a href="{{ wishlist }}" class="material-symbols-outlined" style="text-decoration:none; color:inherit;">favorite</a>
      <a href="{{ account }}" class="material-symbols-outlined" style="text-decoration:none; color:inherit;">person</a>
      <a href="{{ shopping_cart }}" class="material-symbols-outlined" style="text-decoration:none; color:inherit; position:relative;">
        shopping_bag
        <span style="position:absolute; top:-4px; right:-8px; font-size:10px; font-family:var(--nkb-font-body); font-weight:700; background:var(--nkb-primary); color:#fff; width:16px; height:16px; border-radius:50%; display:flex; align-items:center; justify-content:center;">{{ text_items|split(' ')[0] }}</span>
      </a>
    </div>
  </div>
  <nav class="nkb-header__nav">
    {{ menu }}
  </nav>
</header>
