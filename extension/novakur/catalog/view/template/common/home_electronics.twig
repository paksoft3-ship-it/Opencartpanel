{{ header }}
<style>
/* CSS Custom Properties & Base */
:root {
  --nk-bg-dark: #101c22;
  --nk-bg-light: #f5f7f8;
  --nk-bg-panel: #0f172a;
  --nk-bg-panel-alt: #0a1520;
  --nk-accent: #0da2e7;
  --nk-text-light: #ffffff;
  --nk-text-muted: #94a3b8;
  --nk-text-dark: #0f172a;
  --nk-border: rgba(255, 255, 255, 0.1);
  --nk-radius: 2px;
  --nk-font: 'Inter', sans-serif;
}

body {
  margin: 0;
  padding: 0;
  font-family: var(--nk-font);
  background-color: var(--nk-bg-dark);
  color: var(--nk-text-light);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

*, *::before, *::after {
  box-sizing: border-box;
}

a {
  text-decoration: none;
  color: inherit;
  transition: all 0.3s ease;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

button, input {
  font-family: var(--nk-font);
}

.nk-elec-container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Typography Utility */
.nk-elec-title {
  text-transform: uppercase;
  font-weight: 900;
  font-style: italic;
  letter-spacing: -0.02em;
  margin: 0;
}

/* Animations */
[data-anim] {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s cubic-bezier(0.2, 0.8, 0.2, 1), transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
}
[data-anim].is-visible {
  opacity: 1;
  transform: translateY(0);
}
[data-anim-d="1"] { transition-delay: 0.1s; }
[data-anim-d="2"] { transition-delay: 0.2s; }
[data-anim-d="3"] { transition-delay: 0.3s; }
[data-anim-d="4"] { transition-delay: 0.4s; }
[data-anim-d="5"] { transition-delay: 0.5s; }
[data-anim-d="6"] { transition-delay: 0.6s; }

/* 1. HERO SECTION */
.nk-elec-hero {
  display: grid;
  grid-template-columns: 3fr 2fr;
  min-height: 520px;
  background-color: var(--nk-bg-panel);
  overflow: hidden;
}

.nk-elec-hero__content {
  padding: 80px 60px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nk-elec-hero__eyebrow {
  color: var(--nk-accent);
  text-transform: uppercase;
  font-weight: 700;
  font-size: 0.875rem;
  letter-spacing: 0.1em;
  margin-bottom: 1rem;
}

.nk-elec-hero__title {
  font-size: 4rem;
  line-height: 1.1;
  margin-bottom: 1.5rem;
  color: var(--nk-text-light);
}

.nk-elec-hero__desc {
  color: var(--nk-text-muted);
  font-size: 1.125rem;
  margin-bottom: 2.5rem;
  max-width: 500px;
}

.nk-elec-hero__actions {
  display: flex;
  gap: 1rem;
  margin-bottom: 3rem;
}

.nk-elec-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.875rem 2rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-size: 0.875rem;
  border-radius: var(--nk-radius);
  cursor: pointer;
  border: 2px solid transparent;
}

.nk-elec-btn--primary {
  background-color: var(--nk-accent);
  color: var(--nk-text-light);
}

.nk-elec-btn--primary:hover {
  background-color: #0b8ecb;
}

.nk-elec-btn--secondary {
  background-color: transparent;
  color: var(--nk-text-light);
  border-color: var(--nk-text-light);
}

.nk-elec-btn--secondary:hover {
  background-color: var(--nk-text-light);
  color: var(--nk-bg-panel);
}

.nk-elec-hero__trust {
  display: flex;
  gap: 2rem;
}

.nk-elec-trust-badge {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--nk-text-muted);
  font-size: 0.875rem;
  font-weight: 600;
  text-transform: uppercase;
}

.nk-elec-trust-badge svg {
  color: var(--nk-accent);
  width: 20px;
  height: 20px;
}

.nk-elec-hero__visual {
  position: relative;
  background-image: radial-gradient(circle at center, rgba(13, 162, 231, 0.15) 0%, transparent 70%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nk-elec-hero__image {
  position: relative;
  z-index: 2;
  filter: drop-shadow(0 0 30px rgba(13, 162, 231, 0.4));
  transform: scale(1.05);
}

.nk-elec-hero__tag {
  position: absolute;
  background-color: var(--nk-bg-dark);
  border: 1px solid var(--nk-accent);
  color: var(--nk-text-light);
  padding: 0.5rem 1rem;
  border-radius: var(--nk-radius);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  z-index: 3;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
}

.nk-elec-hero__tag--1 { top: 20%; left: 10%; }
.nk-elec-hero__tag--2 { bottom: 25%; right: 10%; }
.nk-elec-hero__tag--3 { top: 50%; right: 5%; }

/* 2. BENEFITS BAR */
.nk-elec-benefits {
  background-color: var(--nk-bg-light);
  border-bottom: 1px solid #e2e8f0;
  padding: 2.5rem 0;
  color: var(--nk-text-dark);
}

.nk-elec-benefits__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

.nk-elec-benefit {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}

.nk-elec-benefit svg {
  color: var(--nk-accent);
  width: 32px;
  height: 32px;
  flex-shrink: 0;
}

.nk-elec-benefit__text h4 {
  margin: 0 0 0.25rem 0;
  font-weight: 800;
  text-transform: uppercase;
  font-size: 0.875rem;
}

.nk-elec-benefit__text p {
  margin: 0;
  color: #64748b;
  font-size: 0.875rem;
}

/* 3. CATEGORY GRID */
.nk-elec-section {
  padding: 5rem 0;
}

.nk-elec-section__header {
  margin-bottom: 3rem;
  display: flex;
  align-items: center;
}

.nk-elec-section__title {
  font-size: 2rem;
  border-left: 4px solid var(--nk-accent);
  padding-left: 1rem;
  color: var(--nk-text-light);
}

.nk-elec-cats__grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 1.5rem;
}

.nk-elec-cat-card {
  background-color: var(--nk-bg-panel);
  border: 1px solid var(--nk-border);
  border-radius: var(--nk-radius);
  padding: 2rem 1rem;
  text-align: center;
  transition: border-color 0.3s ease, transform 0.3s ease;
}

.nk-elec-cat-card:hover {
  border-color: var(--nk-accent);
  transform: translateY(-5px);
}

.nk-elec-cat-card svg {
  color: var(--nk-accent);
  width: 48px;
  height: 48px;
  margin-bottom: 1rem;
}

.nk-elec-cat-card span {
  display: block;
  font-weight: 800;
  text-transform: uppercase;
  font-size: 0.875rem;
  letter-spacing: 0.05em;
}

/* 4. DEALS OF THE DAY */
.nk-elec-deals {
  background-color: var(--nk-bg-panel-alt);
}

.nk-elec-deals__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 3rem;
}

.nk-elec-deals__title-wrap {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.nk-elec-deals__title-wrap svg {
  color: var(--nk-accent);
  width: 36px;
  height: 36px;
}

.nk-elec-countdown {
  display: flex;
  gap: 0.5rem;
}

.nk-elec-countdown-box {
  background-color: var(--nk-bg-panel);
  border: 1px solid var(--nk-border);
  padding: 0.5rem 1rem;
  border-radius: var(--nk-radius);
  text-align: center;
  font-weight: 800;
  font-size: 1.25rem;
  color: var(--nk-accent);
  min-width: 60px;
}

.nk-elec-countdown-box span {
  display: block;
  font-size: 0.625rem;
  color: var(--nk-text-muted);
  text-transform: uppercase;
  margin-top: 0.25rem;
}

.nk-elec-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}

.nk-elec-deal-card {
  background-color: var(--nk-bg-dark);
  border: 1px solid var(--nk-border);
  border-radius: var(--nk-radius);
  overflow: hidden;
  position: relative;
  transition: border-color 0.3s ease;
}

.nk-elec-deal-card:hover {
  border-color: var(--nk-accent);
}

.nk-elec-deal-card__image {
  aspect-ratio: 1 / 1;
  background-color: #ffffff;
  padding: 2rem;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nk-elec-deal-card__badge {
  position: absolute;
  top: 1rem;
  left: 1rem;
  background-color: #ef4444;
  color: white;
  padding: 0.25rem 0.75rem;
  font-size: 0.75rem;
  font-weight: 800;
  border-radius: var(--nk-radius);
  z-index: 2;
}

.nk-elec-deal-card__content {
  padding: 1.5rem;
}

.nk-elec-deal-card__brand {
  color: var(--nk-text-muted);
  font-size: 0.75rem;
  text-transform: uppercase;
  font-weight: 700;
  margin-bottom: 0.25rem;
}

.nk-elec-deal-card__title {
  font-size: 1rem;
  font-weight: 600;
  margin: 0 0 1rem 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: var(--nk-text-light);
}

.nk-elec-deal-card__price {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.nk-elec-deal-card__price-new {
  color: var(--nk-accent);
  font-size: 1.25rem;
  font-weight: 800;
}

.nk-elec-deal-card__price-old {
  color: var(--nk-text-muted);
  text-decoration: line-through;
  font-size: 0.875rem;
}

/* 5. FEATURED SELECTION */
.nk-elec-featured {
  background-color: var(--nk-text-light);
  color: var(--nk-text-dark);
}

.nk-elec-featured .nk-elec-section__title {
  color: var(--nk-text-dark);
}

.nk-elec-featured__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 3rem;
}

.nk-elec-tabs {
  display: flex;
  gap: 1rem;
}

.nk-elec-tab {
  background: transparent;
  border: 1px solid #e2e8f0;
  padding: 0.5rem 1.5rem;
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.75rem;
  border-radius: var(--nk-radius);
  color: #64748b;
  cursor: pointer;
}

.nk-elec-tab.is-active {
  background-color: var(--nk-accent);
  border-color: var(--nk-accent);
  color: var(--nk-text-light);
}

.nk-elec-product-card {
  position: relative;
  group: hover;
}

.nk-elec-product-card__image-wrap {
  aspect-ratio: 4 / 5;
  background-color: #f8fafc;
  position: relative;
  border-radius: var(--nk-radius);
  overflow: hidden;
  margin-bottom: 1rem;
}

.nk-elec-product-card__image-wrap img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 2rem;
  transition: transform 0.5s ease;
}

.nk-elec-product-card:hover .nk-elec-product-card__image-wrap img {
  transform: scale(1.05);
}

.nk-elec-product-card__overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.nk-elec-product-card:hover .nk-elec-product-card__overlay {
  opacity: 1;
}

.nk-elec-icon-btn {
  width: 44px;
  height: 44px;
  background-color: var(--nk-text-light);
  color: var(--nk-text-dark);
  border: none;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.nk-elec-icon-btn:hover {
  background-color: var(--nk-accent);
  color: var(--nk-text-light);
}

.nk-elec-product-card__info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.nk-elec-product-card__cat {
  font-size: 0.75rem;
  color: #64748b;
  font-style: italic;
  margin-bottom: 0.25rem;
  display: block;
}

.nk-elec-product-card__name {
  font-weight: 700;
  font-size: 1rem;
  margin: 0 0 0.5rem 0;
  color: var(--nk-bg-panel);
}

.nk-elec-product-card__price {
  font-weight: 900;
  color: var(--nk-accent);
}

.nk-elec-add-btn {
  width: 40px;
  height: 40px;
  border: 1px solid #e2e8f0;
  background: transparent;
  color: var(--nk-bg-panel);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--nk-radius);
  cursor: pointer;
  transition: all 0.3s ease;
}

.nk-elec-add-btn:hover {
  border-color: var(--nk-accent);
  background-color: var(--nk-accent);
  color: var(--nk-text-light);
}

/* 6. PROMO BANNER STRIP */
.nk-elec-promo-strip {
  padding: 2rem 0;
}

.nk-elec-promo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}

.nk-elec-promo-banner {
  height: 280px;
  position: relative;
  border-radius: var(--nk-radius);
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 3rem;
  background-color: var(--nk-bg-panel);
}

.nk-elec-promo-banner img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.6;
  transition: transform 0.8s ease;
}

.nk-elec-promo-banner:hover img {
  transform: scale(1.05);
}

.nk-elec-promo-content {
  position: relative;
  z-index: 2;
}

.nk-elec-promo-content h3 {
  font-size: 2rem;
  margin: 0 0 0.5rem 0;
  color: var(--nk-text-light);
}

.nk-elec-promo-content p {
  font-size: 1.125rem;
  color: var(--nk-text-light);
  margin: 0 0 1.5rem 0;
  font-weight: 300;
}

.nk-elec-promo-link {
  color: var(--nk-accent);
  font-weight: 800;
  text-transform: uppercase;
  font-size: 0.875rem;
  letter-spacing: 0.05em;
  display: inline-flex;
  align-items: center;
}

.nk-elec-promo-link:hover {
  color: var(--nk-text-light);
}

/* 7. BRANDS */
.nk-elec-brands {
  background-color: var(--nk-bg-light);
  border-top: 1px solid #e2e8f0;
  border-bottom: 1px solid #e2e8f0;
  padding: 4rem 0;
}

.nk-elec-brands-flex {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 2rem;
}

.nk-elec-brand-logo {
  font-size: 1.5rem;
  font-weight: 900;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transition: color 0.3s ease;
}

.nk-elec-brand-logo:hover {
  color: var(--nk-bg-panel);
}

/* 8. NEWSLETTER */
.nk-elec-newsletter {
  background-color: var(--nk-bg-panel);
  padding: 6rem 0;
  text-align: center;
}

.nk-elec-newsletter__eyebrow {
  color: var(--nk-accent);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-size: 0.875rem;
  margin-bottom: 1rem;
}

.nk-elec-newsletter__title {
  font-size: 2.5rem;
  margin: 0 0 1rem 0;
  color: var(--nk-text-light);
}

.nk-elec-newsletter__desc {
  color: var(--nk-text-muted);
  font-size: 1.125rem;
  margin: 0 auto 2.5rem auto;
  max-width: 500px;
}

.nk-elec-newsletter-form {
  display: flex;
  max-width: 500px;
  margin: 0 auto;
}

.nk-elec-newsletter-input {
  flex: 1;
  background-color: var(--nk-bg-dark);
  border: 1px solid var(--nk-border);
  padding: 1rem 1.5rem;
  color: var(--nk-text-light);
  border-radius: var(--nk-radius) 0 0 var(--nk-radius);
  outline: none;
  font-size: 1rem;
}

.nk-elec-newsletter-input:focus {
  border-color: var(--nk-accent);
}

.nk-elec-newsletter-btn {
  background-color: var(--nk-accent);
  color: var(--nk-text-light);
  border: none;
  padding: 0 2rem;
  font-weight: 800;
  text-transform: uppercase;
  border-radius: 0 var(--nk-radius) var(--nk-radius) 0;
  cursor: pointer;
  transition: background-color 0.3s ease;
}

.nk-elec-newsletter-btn:hover {
  background-color: #0b8ecb;
}

/* RESPONSIVE */
@media (max-width: 1024px) {
  .nk-elec-cats__grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .nk-elec-grid-4 {
    grid-template-columns: repeat(2, 1fr);
  }
  .nk-elec-benefits__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .nk-elec-hero {
    grid-template-columns: 1fr;
  }
  .nk-elec-hero__visual {
    order: -1;
    padding: 3rem 0;
  }
  .nk-elec-hero__content {
    padding: 3rem 20px;
  }
  .nk-elec-hero__title {
    font-size: 2.5rem;
  }
  .nk-elec-promo-grid {
    grid-template-columns: 1fr;
  }
  .nk-elec-featured__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .nk-elec-tabs {
    flex-wrap: wrap;
  }
}

@media (max-width: 560px) {
  .nk-elec-cats__grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .nk-elec-grid-4 {
    grid-template-columns: 1fr;
  }
  .nk-elec-benefits__grid {
    grid-template-columns: 1fr;
  }
  .nk-elec-deals__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .nk-elec-hero__actions {
    flex-direction: column;
  }
  .nk-elec-btn {
    width: 100%;
  }
  .nk-elec-newsletter-form {
    flex-direction: column;
    gap: 1rem;
  }
  .nk-elec-newsletter-input, .nk-elec-newsletter-btn {
    width: 100%;
    border-radius: var(--nk-radius);
  }
  .nk-elec-newsletter-btn {
    padding: 1rem;
  }
}
</style>

<!-- 1. HERO -->
<section class="nk-elec-hero">
  <div class="nk-elec-hero__content" data-anim data-anim-d="1">
    <span class="nk-elec-hero__eyebrow">Next Generation Performance</span>
    <h1 class="nk-elec-title nk-elec-hero__title">Unleash Ultimate Power</h1>
    <p class="nk-elec-hero__desc">Discover the new standard of extreme gaming and professional computing with our latest lineup of cutting-edge hardware.</p>
    <div class="nk-elec-hero__actions">
      <a href="#" class="nk-elec-btn nk-elec-btn--primary">Shop Now</a>
      <a href="#" class="nk-elec-btn nk-elec-btn--secondary">View Specs</a>
    </div>
    <div class="nk-elec-hero__trust">
      <div class="nk-elec-trust-badge">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        Official Warranty
      </div>
      <div class="nk-elec-trust-badge">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Global Shipping
      </div>
    </div>
  </div>
  <div class="nk-elec-hero__visual" data-anim data-anim-d="2">
    <div class="nk-elec-hero__tag nk-elec-hero__tag--1" data-anim data-anim-d="3">INTEL i9</div>
