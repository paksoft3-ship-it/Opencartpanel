<!DOCTYPE html>
<html lang="{{ language }}" dir="{{ direction }}">
<head>
  <meta charset="{{ charset }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="{{ description }}">
  <meta name="keywords" content="{{ keywords }}">
  <title>{{ title }}</title>
  <base href="{{ base }}">
  {% for link in links %}<link rel="{{ link.rel }}" href="{{ link.href }}">{% endfor %}

  <!-- Google Fonts: Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- NovaKur Minimal Theme CSS -->
  <link rel="stylesheet" href="{{ HTTP_SERVER }}extension/novakur_minimal/catalog/view/assets/dist/css/main.css">

  <!-- Theme CSS Variables -->
  <style>
    :root {
      --nm-accent: {{ nm_accent_color|default('#111111') }};
      --nm-width: {{ nm_container_width|default(1200) }}px;
      --nm-font: '{{ nm_base_font|default('Inter') }}', system-ui, sans-serif;
    }
  </style>

  {% for style in styles %}
  <link rel="stylesheet" href="{{ style.href }}" type="text/css" media="{{ style.media }}">
  {% endfor %}

  {{ analytics }}
</head>
<body class="nm-body">
<div class="nm-wrap">

  <!-- Announcement Bar -->
  <div class="nm-announcement" role="banner">
    <div class="nm-container">
      <span>Free Shipping on Orders Over $50 &mdash; Use code <strong>FREESHIP</strong></span>
    </div>
  </div>

  <!-- Header -->
  <header class="nm-header" role="banner">
    <div class="nm-container nm-header-inner">

      <!-- Logo -->
      <a href="{{ home }}" class="nm-logo" aria-label="{{ store }}">
        {% if theme_novakur_minimal_logo %}
          <img src="{{ HTTP_SERVER }}image/{{ theme_novakur_minimal_logo }}" alt="{{ store }}" class="nm-logo-img">
        {% else %}
          <span class="nm-logo-text">{{ store }}</span>
        {% endif %}
      </a>

      <!-- Search Form -->
      <form class="nm-search-form" action="{{ action_search|default(base ~ 'index.php?route=product/search') }}" method="get" role="search">
        <input
          type="search"
          name="search"
          class="nm-search-input"
          placeholder="Search products…"
          value="{{ search|default('') }}"
          aria-label="Search products"
          autocomplete="off"
        >
        <button type="submit" class="nm-search-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>

      <!-- Desktop Navigation -->
      <nav class="nm-nav" role="navigation" aria-label="Main navigation">
        <ul class="nm-nav-list">
          <li class="nm-nav-item"><a href="{{ home }}" class="nm-nav-link">Home</a></li>
          {% if menu is defined %}
            {% for item in menu %}
            <li class="nm-nav-item{% if item.children is defined and item.children %} nm-has-dropdown{% endif %}">
              <a href="{{ item.href }}" class="nm-nav-link">{{ item.name }}</a>
              {% if item.children is defined and item.children %}
              <ul class="nm-dropdown">
                {% for child in item.children %}
                <li><a href="{{ child.href }}" class="nm-dropdown-link">{{ child.name }}</a></li>
                {% endfor %}
              </ul>
              {% endif %}
            </li>
            {% endfor %}
          {% elseif menu_items is defined %}
            {% for item in menu_items %}
            <li class="nm-nav-item">
              <a href="{{ item.href }}" class="nm-nav-link">{{ item.name }}</a>
            </li>
            {% endfor %}
          {% else %}
            <li class="nm-nav-item"><a href="{{ base }}index.php?route=product/category" class="nm-nav-link">Shop</a></li>
            <li class="nm-nav-item"><a href="{{ base }}index.php?route=product/special" class="nm-nav-link">Sale</a></li>
            <li class="nm-nav-item"><a href="{{ base }}index.php?route=information/contact" class="nm-nav-link">Contact</a></li>
          {% endif %}
        </ul>
      </nav>

      <!-- Header Actions -->
      <div class="nm-header-actions">

        <!-- Wishlist -->
        <a href="{{ base }}index.php?route=account/wishlist" class="nm-action-btn nm-wishlist-btn" aria-label="Wishlist{% if wishlists is defined and wishlists %} ({{ wishlists }}){% endif %}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          {% if wishlists is defined and wishlists > 0 %}
          <span class="nm-cart-badge">{{ wishlists }}</span>
          {% endif %}
        </a>

        <!-- Account -->
        <div class="nm-account-wrap">
          <button class="nm-action-btn nm-account-btn" aria-label="Account" aria-expanded="false" aria-haspopup="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
          </button>
          <div class="nm-account-dropdown" role="menu">
            {% if logged %}
              <a href="{{ account }}" class="nm-account-link" role="menuitem">My Account</a>
              <a href="{{ base }}index.php?route=account/order" class="nm-account-link" role="menuitem">Orders</a>
              <a href="{{ base }}index.php?route=account/wishlist" class="nm-account-link" role="menuitem">Wishlist</a>
              <a href="{{ base }}index.php?route=account/logout" class="nm-account-link" role="menuitem">Sign Out</a>
            {% else %}
              <a href="{{ base }}index.php?route=account/login" class="nm-account-link" role="menuitem">Sign In</a>
              <a href="{{ base }}index.php?route=account/register" class="nm-account-link" role="menuitem">Register</a>
            {% endif %}
          </div>
        </div>

        <!-- Cart -->
        <a href="{{ base }}index.php?route=checkout/cart" class="nm-action-btn nm-cart-btn" aria-label="Shopping cart">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <span class="nm-cart-badge" id="nm-cart-badge" aria-live="polite">{{ cart_count|default(0) }}</span>
        </a>

        <!-- Hamburger (Mobile) -->
        <button class="nm-hamburger nm-action-btn" aria-label="Open menu" aria-expanded="false" aria-controls="nm-mobile-nav">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>

      </div><!-- /.nm-header-actions -->
    </div><!-- /.nm-container -->
  </header><!-- /.nm-header -->

  <!-- Mobile Navigation Drawer -->
  <div class="nm-mobile-overlay" id="nm-mobile-overlay" aria-hidden="true"></div>
  <nav class="nm-mobile-nav" id="nm-mobile-nav" role="navigation" aria-label="Mobile navigation" aria-hidden="true">
    <div class="nm-mobile-nav-header">
      <a href="{{ home }}" class="nm-logo nm-mobile-logo">{{ store }}</a>
      <button class="nm-mobile-close nm-action-btn" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <ul class="nm-mobile-nav-list">
      <li><a href="{{ home }}" class="nm-mobile-nav-link">Home</a></li>
      {% if menu is defined %}
        {% for item in menu %}
        <li>
          <a href="{{ item.href }}" class="nm-mobile-nav-link">{{ item.name }}</a>
          {% if item.children is defined and item.children %}
          <ul class="nm-mobile-submenu">
            {% for child in item.children %}
            <li><a href="{{ child.href }}" class="nm-mobile-nav-link nm-mobile-nav-link--sub">{{ child.name }}</a></li>
            {% endfor %}
          </ul>
          {% endif %}
        </li>
        {% endfor %}
      {% else %}
        <li><a href="{{ base }}index.php?route=product/category" class="nm-mobile-nav-link">Shop</a></li>
        <li><a href="{{ base }}index.php?route=product/special" class="nm-mobile-nav-link">Sale</a></li>
        <li><a href="{{ base }}index.php?route=information/contact" class="nm-mobile-nav-link">Contact</a></li>
      {% endif %}
      <li class="nm-mobile-nav-divider"></li>
      {% if logged %}
        <li><a href="{{ account }}" class="nm-mobile-nav-link">My Account</a></li>
        <li><a href="{{ base }}index.php?route=account/logout" class="nm-mobile-nav-link">Sign Out</a></li>
      {% else %}
        <li><a href="{{ base }}index.php?route=account/login" class="nm-mobile-nav-link">Sign In</a></li>
        <li><a href="{{ base }}index.php?route=account/register" class="nm-mobile-nav-link">Register</a></li>
      {% endif %}
    </ul>
  </nav><!-- /.nm-mobile-nav -->

  <!-- Alert / Success messages -->
  {% if alert is defined and alert %}
  <div class="nm-container"><div class="nm-alert nm-alert--error" role="alert">{{ alert }}</div></div>
  {% endif %}
  {% if success is defined and success %}
  <div class="nm-container"><div class="nm-alert nm-alert--success" role="alert">{{ success }}</div></div>
  {% endif %}

  <main class="nm-main" id="nm-main">
