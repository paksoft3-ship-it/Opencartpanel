{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container nm-listing">
  <div class="nm-listing-header">
    <div>
      <h1 class="nm-listing-title">{{ heading_1 }}</h1>
      {% if results %}<p class="nm-listing-count" style="margin-top:6px;">{{ results }}</p>{% endif %}
    </div>
    <div class="nm-listing-controls">
      {% if sorts %}<select class="nm-listing-select" onchange="location=this.value">{% for sort in sorts %}<option value="{{ sort.href }}" {% if sort.selected %}selected{% endif %}>{{ sort.text }}</option>{% endfor %}</select>{% endif %}
    </div>
  </div>
  {% if products %}
  <div class="nm-product-grid">
    {% for product in products %}
    <div class="nm-card">
      <a href="{{ product.href }}" class="nm-card-image"><img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy"><span class="nm-card-badge">Sale</span></a>
      <div class="nm-card-body">
        <a href="{{ product.href }}" class="nm-card-name">{{ product.name }}</a>
        <div class="nm-card-price"><span class="nm-price nm-price-sale">{{ product.special }}</span><span class="nm-price-old">{{ product.price }}</span></div>
        <div class="nm-card-cta"><button class="nm-btn nm-btn-primary nm-btn-sm nm-btn-full" data-nm-add-to-cart data-product-id="{{ product.product_id }}">Add to Cart</button></div>
      </div>
    </div>
    {% endfor %}
  </div>
  {% if pagination %}<div class="nm-pagination">{{ pagination }}</div>{% endif %}
  {% else %}
  <div style="text-align:center;padding:80px 0;"><p style="color:var(--nm-text-muted);">No special offers at the moment.</p></div>
  {% endif %}
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
