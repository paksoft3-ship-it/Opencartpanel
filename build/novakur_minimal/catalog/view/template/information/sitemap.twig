{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container" style="padding:48px 24px;">
  <h1 style="font-size:32px;font-weight:700;margin-bottom:32px;">Sitemap</h1>
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:40px;">
    {% if categories %}
    <div>
      <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;color:var(--nm-text-muted);">Categories</h2>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
        {% for category in categories %}
        <li><a href="{{ category.href }}" style="font-size:14px;color:var(--nm-text);">{{ category.name }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
    {% if informations %}
    <div>
      <h2 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;color:var(--nm-text-muted);">Information</h2>
      <ul style="list-style:none;display:flex;flex-direction:column;gap:8px;">
        {% for information in informations %}
        <li><a href="{{ information.href }}" style="font-size:14px;color:var(--nm-text);">{{ information.title }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
