{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container">
  <div class="nm-account-grid">
    <nav>
      <ul class="nm-account-nav">
        <li><a href="{{ order_list }}" class="{{ route is defined and 'account/order' in route ? 'active' : '' }}">Orders</a></li>
        <li><a href="{{ wishlist }}" class="{{ route is defined and 'account/wishlist' in route ? 'active' : '' }}">Wishlist</a></li>
        <li><a href="{{ edit }}" class="{{ route is defined and 'account/edit' in route ? 'active' : '' }}">Edit Account</a></li>
        <li><a href="{{ password }}" class="{{ route is defined and 'account/password' in route ? 'active' : '' }}">Change Password</a></li>
        <li><a href="{{ address }}" class="{{ route is defined and 'account/address' in route ? 'active' : '' }}">Addresses</a></li>
        <li><a href="{{ newsletter }}" class="{{ route is defined and 'account/newsletter' in route ? 'active' : '' }}">Newsletter</a></li>
        <li><a href="{{ logout }}">Logout</a></li>
      </ul>
    </nav>
    <div>
      <h1 style="font-size:28px;font-weight:700;margin-bottom:24px;letter-spacing:-0.02em;">My Account</h1>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;">
        <a href="{{ order_list }}" style="border:1px solid var(--nm-border);padding:24px;display:block;transition:border-color 200ms ease;">
          <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Orders</div>
          <div style="font-size:13px;color:var(--nm-text-muted);">View your order history</div>
        </a>
        <a href="{{ wishlist }}" style="border:1px solid var(--nm-border);padding:24px;display:block;transition:border-color 200ms ease;">
          <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Wishlist</div>
          <div style="font-size:13px;color:var(--nm-text-muted);">Products you've saved</div>
        </a>
        <a href="{{ edit }}" style="border:1px solid var(--nm-border);padding:24px;display:block;transition:border-color 200ms ease;">
          <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Profile</div>
          <div style="font-size:13px;color:var(--nm-text-muted);">Update your details</div>
        </a>
        <a href="{{ address }}" style="border:1px solid var(--nm-border);padding:24px;display:block;transition:border-color 200ms ease;">
          <div style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;">Addresses</div>
          <div style="font-size:13px;color:var(--nm-text-muted);">Manage shipping addresses</div>
        </a>
      </div>
    </div>
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
