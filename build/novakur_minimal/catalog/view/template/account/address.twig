{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container" style="padding:40px 24px;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32px;">
    <h1 style="font-size:28px;font-weight:700;">Addresses</h1>
    <a href="{{ add }}" class="nm-btn nm-btn-outline">+ New Address</a>
  </div>
  {% if addresses %}
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;">
    {% for address in addresses %}
    <div style="border:1px solid var(--nm-border);padding:24px;">
      <p style="font-size:14px;line-height:1.8;">{{ address.address_1 }}{% if address.address_2 %}, {{ address.address_2 }}{% endif %}<br>{{ address.city }}{% if address.zone %}, {{ address.zone }}{% endif %} {{ address.postcode }}<br>{{ address.country }}</p>
      <div style="display:flex;gap:8px;margin-top:16px;">
        <a href="{{ address.edit }}" class="nm-btn nm-btn-ghost nm-btn-sm">Edit</a>
        <a href="{{ address.delete }}" class="nm-btn nm-btn-ghost nm-btn-sm">Delete</a>
      </div>
    </div>
    {% endfor %}
  </div>
  {% else %}
  <p style="color:var(--nm-text-muted);">No addresses saved.</p>
  {% endif %}
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
