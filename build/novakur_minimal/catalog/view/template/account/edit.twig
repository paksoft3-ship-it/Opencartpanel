{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container">
  <div style="max-width:560px;margin:48px auto;">
    <h1 style="font-size:28px;font-weight:700;margin-bottom:32px;">Edit Account</h1>
    <form action="{{ action }}" method="post">
      <div class="nm-form-row">
        <div class="nm-form-group"><label>First Name *</label><input type="text" name="firstname" value="{{ firstname }}" required></div>
        <div class="nm-form-group"><label>Last Name *</label><input type="text" name="lastname" value="{{ lastname }}" required></div>
      </div>
      <div class="nm-form-group"><label>Email Address *</label><input type="email" name="email" value="{{ email }}" required></div>
      <div class="nm-form-group"><label>Phone</label><input type="tel" name="telephone" value="{{ telephone }}"></div>
      <div style="display:flex;gap:12px;margin-top:8px;">
        <button type="submit" class="nm-btn nm-btn-primary">Save Changes</button>
        <a href="{{ back|default('index.php?route=account/account') }}" class="nm-btn nm-btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
