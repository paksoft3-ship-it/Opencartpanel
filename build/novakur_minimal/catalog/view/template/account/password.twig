{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container">
  <div style="max-width:440px;margin:48px auto;">
    <h1 style="font-size:28px;font-weight:700;margin-bottom:32px;">Change Password</h1>
    <form action="{{ action }}" method="post">
      <div class="nm-form-group"><label>New Password *</label><input type="password" name="password" required></div>
      <div class="nm-form-group"><label>Confirm Password *</label><input type="password" name="confirm" required></div>
      <div style="display:flex;gap:12px;margin-top:8px;">
        <button type="submit" class="nm-btn nm-btn-primary">Update Password</button>
        <a href="{{ back|default('index.php?route=account/account') }}" class="nm-btn nm-btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
