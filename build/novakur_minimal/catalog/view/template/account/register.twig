{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container">
  <div style="max-width:560px;margin:64px auto;">
    <h1 style="font-size:28px;font-weight:700;margin-bottom:8px;">Create Account</h1>
    <p style="font-size:14px;color:var(--nm-text-muted);margin-bottom:32px;">Join us for a better shopping experience.</p>
    <form action="{{ action }}" method="post">
      <div class="nm-form-row">
        <div class="nm-form-group"><label>First Name *</label><input type="text" name="firstname" required></div>
        <div class="nm-form-group"><label>Last Name *</label><input type="text" name="lastname" required></div>
      </div>
      <div class="nm-form-group"><label>Email Address *</label><input type="email" name="email" required></div>
      <div class="nm-form-group"><label>Phone</label><input type="tel" name="telephone"></div>
      <div class="nm-form-row">
        <div class="nm-form-group"><label>Password *</label><input type="password" name="password" required></div>
        <div class="nm-form-group"><label>Confirm Password *</label><input type="password" name="confirm" required></div>
      </div>
      <div style="margin:16px 0;">
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-size:13px;">
          <input type="checkbox" name="newsletter" value="1" style="margin-top:2px;">
          <span>Subscribe to our newsletter for offers and updates.</span>
        </label>
      </div>
      {% if agree %}
      <div style="margin:16px 0;">
        <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;font-size:13px;">
          <input type="checkbox" name="agree" value="1" required style="margin-top:2px;">
          <span>{{ text_agree }}</span>
        </label>
      </div>
      {% endif %}
      <button type="submit" class="nm-btn nm-btn-primary nm-btn-full" style="margin-top:8px;">Create Account</button>
      <p style="text-align:center;font-size:13px;color:var(--nm-text-muted);margin-top:16px;">Already have an account? <a href="{{ login|default('index.php?route=account/login') }}" style="color:var(--nm-text);text-decoration:underline;">Sign in</a></p>
    </form>
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
