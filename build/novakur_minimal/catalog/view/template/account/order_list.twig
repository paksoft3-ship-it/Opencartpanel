{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container" style="padding:40px 24px;">
  <h1 style="font-size:28px;font-weight:700;margin-bottom:32px;">Order History</h1>
  {% if orders %}
  <table class="nm-cart-table">
    <thead>
      <tr>
        <th>Order #</th>
        <th>Date</th>
        <th>Status</th>
        <th style="text-align:right;">Total</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% for order in orders %}
      <tr>
        <td style="font-size:14px;font-weight:600;">#{{ order.order_id }}</td>
        <td style="font-size:14px;color:var(--nm-text-muted);">{{ order.date_added }}</td>
        <td><span style="font-size:12px;font-weight:600;background:var(--nm-surface);padding:4px 10px;border:1px solid var(--nm-border);">{{ order.status }}</span></td>
        <td style="text-align:right;font-size:14px;font-weight:600;">{{ order.total }}</td>
        <td><a href="{{ order.view }}" class="nm-btn nm-btn-ghost nm-btn-sm">View</a></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% if pagination %}<div class="nm-pagination">{{ pagination }}</div>{% endif %}
  {% else %}
  <p style="color:var(--nm-text-muted);">No orders yet. <a href="{{ continue|default('index.php?route=common/home') }}" style="color:var(--nm-text);text-decoration:underline;">Start shopping</a></p>
  {% endif %}
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
