{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container" style="padding:40px 24px;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32px;">
    <h1 style="font-size:28px;font-weight:700;">Order #{{ order_id }}</h1>
    <a href="{{ back|default('index.php?route=account/order') }}" class="nm-btn nm-btn-ghost">← Back to Orders</a>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:32px;">
    <div>
      <h3 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Billing Address</h3>
      <p style="font-size:14px;color:var(--nm-text-muted);line-height:1.8;">{{ payment_address }}</p>
    </div>
    {% if shipping_address %}
    <div>
      <h3 style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Shipping Address</h3>
      <p style="font-size:14px;color:var(--nm-text-muted);line-height:1.8;">{{ shipping_address }}</p>
    </div>
    {% endif %}
  </div>
  {% if products %}
  <table class="nm-cart-table">
    <thead><tr><th>Product</th><th>Model</th><th>Qty</th><th style="text-align:right;">Price</th><th style="text-align:right;">Total</th></tr></thead>
    <tbody>
      {% for product in products %}
      <tr>
        <td style="font-size:14px;">{{ product.name }}</td>
        <td style="font-size:13px;color:var(--nm-text-muted);">{{ product.model }}</td>
        <td style="font-size:14px;">{{ product.quantity }}</td>
        <td style="text-align:right;font-size:14px;">{{ product.price }}</td>
        <td style="text-align:right;font-size:14px;font-weight:600;">{{ product.total }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}
  {% if totals %}
  <div style="max-width:320px;margin-left:auto;margin-top:16px;">
    {% for total in totals %}
    <div class="nm-cart-total-row"><span>{{ total.title }}</span><span>{{ total.text }}</span></div>
    {% endfor %}
  </div>
  {% endif %}
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
