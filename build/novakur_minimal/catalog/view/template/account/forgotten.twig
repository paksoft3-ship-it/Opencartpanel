{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
<div class="nm-container">
  <div class="nm-auth">
    <h1 class="nm-auth-title">Reset Password</h1>
    <p class="nm-auth-subtitle">Enter your email address and we'll send you a reset link.</p>
    <form action="{{ action }}" method="post">
      <div class="nm-form-group"><label>Email Address *</label><input type="email" name="email" required autofocus></div>
      <button type="submit" class="nm-btn nm-btn-primary nm-btn-full">Send Reset Link</button>
    </form>
    <p style="text-align:center;font-size:13px;color:var(--nm-text-muted);margin-top:20px;"><a href="{{ login|default('index.php?route=account/login') }}" style="color:var(--nm-text);text-decoration:underline;">Back to Sign In</a></p>
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
