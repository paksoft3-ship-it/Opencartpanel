{% include 'extension/novakur_minimal/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_minimal/catalog/view/template/common/breadcrumb.twig' %}
<div class="nm-container">
  <div style="max-width:560px;margin:48px auto;">
    <h1 style="font-size:28px;font-weight:700;margin-bottom:32px;">{% if address_id is defined and address_id %}Edit Address{% else %}New Address{% endif %}</h1>
    <form action="{{ action }}" method="post">
      <div class="nm-form-row">
        <div class="nm-form-group"><label>First Name *</label><input type="text" name="firstname" value="{{ firstname|default('') }}" required></div>
        <div class="nm-form-group"><label>Last Name *</label><input type="text" name="lastname" value="{{ lastname|default('') }}" required></div>
      </div>
      <div class="nm-form-group"><label>Company</label><input type="text" name="company" value="{{ company|default('') }}"></div>
      <div class="nm-form-group"><label>Address 1 *</label><input type="text" name="address_1" value="{{ address_1|default('') }}" required></div>
      <div class="nm-form-group"><label>Address 2</label><input type="text" name="address_2" value="{{ address_2|default('') }}"></div>
      <div class="nm-form-row">
        <div class="nm-form-group"><label>City *</label><input type="text" name="city" value="{{ city|default('') }}" required></div>
        <div class="nm-form-group"><label>Postcode *</label><input type="text" name="postcode" value="{{ postcode|default('') }}" required></div>
      </div>
      <div class="nm-form-row">
        <div class="nm-form-group"><label>Country *</label>
          <select name="country_id" class="nm-option-select">
            {% if countries is defined %}{% for country in countries %}<option value="{{ country.country_id }}" {% if country.country_id == country_id %}selected{% endif %}>{{ country.name }}</option>{% endfor %}{% endif %}
          </select>
        </div>
        <div class="nm-form-group"><label>Region *</label>
          <select name="zone_id" class="nm-option-select">
            {% if zones is defined %}{% for zone in zones %}<option value="{{ zone.zone_id }}" {% if zone.zone_id == zone_id %}selected{% endif %}>{{ zone.name }}</option>{% endfor %}{% endif %}
          </select>
        </div>
      </div>
      <div style="display:flex;gap:12px;margin-top:8px;">
        <button type="submit" class="nm-btn nm-btn-primary">Save Address</button>
        <a href="{{ back|default('index.php?route=account/address') }}" class="nm-btn nm-btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
{% include 'extension/novakur_minimal/catalog/view/template/common/footer.twig' %}
