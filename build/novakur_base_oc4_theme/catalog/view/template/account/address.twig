{# NovaKur Base: Account address book route #}
{{ header }}

{% include 'catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}

<main id="content" class="nk-account-page nk-account-page--address">
  <div class="nk-global-container__inner">
    <div class="nk-account-layout">
      <aside class="nk-account-layout__sidebar" aria-label="Account navigation">
        <details class="nk-account-layout__nav-wrap" open>
          <summary class="nk-account-layout__nav-toggle">My Account</summary>
          <nav class="nk-account-layout__nav">
            <a class="nk-account-layout__link" href="{{ account|default('#') }}">Dashboard</a>
            <a class="nk-account-layout__link" href="{{ order|default('#') }}">Orders</a>
            <a class="nk-account-layout__link" href="{{ wishlist|default('#') }}">Wishlist</a>
            <a class="nk-account-layout__link is-active" href="{{ address|default('#') }}">Address Book</a>
            <a class="nk-account-layout__link" href="{{ logout|default('#') }}">Logout</a>
          </nav>
        </details>
      </aside>

      <section class="nk-account-layout__content" aria-label="Address book">
        <header class="nk-account-page__head nk-account-page__head--split">
          <h1 class="nk-account-page__title">{{ heading_title|default('Address Book') }}</h1>
          {% include 'catalog/view/template/component/ui/button.twig' with {
            button_tag: 'a',
            href: add|default('#'),
            button_label: 'Add Address',
            button_variant: 'primary',
            button_size: 'sm'
          } only %}
        </header>

        {% if addresses|default([]) %}
          <div class="nk-account-addresses">
            {% for address_item in addresses %}
              <article class="nk-account-addresses__item">
                <div class="nk-account-addresses__text">{{ address_item.address|default(address_item|default('')) }}</div>
                <div class="nk-account-addresses__actions">
                  {% include 'catalog/view/template/component/ui/button.twig' with {
                    button_tag: 'a',
                    href: address_item.update|default('#'),
                    button_label: 'Edit',
                    button_variant: 'ghost',
                    button_size: 'sm'
                  } only %}
                  {% include 'catalog/view/template/component/ui/button.twig' with {
                    button_tag: 'a',
                    href: address_item.delete|default('#'),
                    button_label: 'Remove',
                    button_variant: 'ghost',
                    button_size: 'sm'
                  } only %}
                </div>
              </article>
            {% endfor %}
          </div>
        {% else %}
          <p class="nk-account-page__empty">No saved addresses found.</p>
        {% endif %}
      </section>
    </div>
  </div>
</main>

{{ footer }}
