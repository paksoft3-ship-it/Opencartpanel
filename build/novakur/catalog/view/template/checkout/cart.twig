{# NovaKur Base: Cart page (Tailwind) #}
{{ header }}

<main class="max-w-7xl mx-auto px-4 lg:px-8 py-8">

  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}

  <div class="mb-8">
    <h1 class="text-3xl font-black text-slate-900">{{ heading_title|default('Shopping Cart') }}</h1>
    {% set product_list = products|default([]) %}
    {% if product_list %}
      <p class="text-slate-500 mt-1">You have {{ product_list|length }} item{{ product_list|length != 1 ? 's' : '' }} in your cart.</p>
    {% endif %}
  </div>

  {% set product_list = products|default([]) %}
  {% if product_list %}
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">

    {# Cart items #}
    <div class="lg:col-span-8">
      <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
        <table class="w-full text-left">
          <thead class="hidden sm:table-header-group border-b border-slate-200 bg-slate-50">
            <tr>
              <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Product</th>
              <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Price</th>
              <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-center">Qty</th>
              <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500 text-right">Total</th>
              <th class="w-10"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200">
            {% for product in product_list %}
              <tr id="cart-row-{{ product.cart_id }}" class="group">
                <td class="px-6 py-5">
                  <div class="flex items-center gap-4">
                    {% if product.thumb is defined and product.thumb %}
                      <a href="{{ product.href|default('#') }}" class="shrink-0 w-20 h-20 rounded-xl overflow-hidden bg-slate-100 no-underline block">
                        <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover"/>
                      </a>
                    {% endif %}
                    <div>
                      <a href="{{ product.href|default('#') }}" class="font-bold text-slate-900 hover:text-primary no-underline">{{ product.name }}</a>
                      {% if product.option is defined and product.option %}
                        {% for option in product.option %}
                          <p class="text-xs text-slate-500 mt-0.5">{{ option.name }}: {{ option.value }}</p>
                        {% endfor %}
                      {% endif %}
                    </div>
                  </div>
                </td>
                <td class="px-6 py-5 text-slate-700 font-medium">{{ product.price|default('') }}</td>
                <td class="px-6 py-5 text-center">
                  <div class="flex items-center justify-center rounded-xl border border-slate-200 w-fit mx-auto overflow-hidden">
                    <button type="button" class="px-3 py-2 text-slate-400 hover:text-primary transition-colors" onclick="updateQty({{ product.cart_id|default(loop.index) }}, -1)">
                      <span class="material-symbols-outlined text-sm">remove</span>
                    </button>
                    <input type="number" id="qty-{{ product.cart_id|default(loop.index) }}" value="{{ product.quantity|default(1) }}" min="1" class="w-12 border-0 text-center font-bold text-sm text-slate-900 focus:ring-0 py-2"/>
                    <button type="button" class="px-3 py-2 text-slate-400 hover:text-primary transition-colors" onclick="updateQty({{ product.cart_id|default(loop.index) }}, 1)">
                      <span class="material-symbols-outlined text-sm">add</span>
                    </button>
                  </div>
                </td>
                <td class="px-6 py-5 text-right font-bold text-slate-900">{{ product.total|default('') }}</td>
                <td class="px-6 py-5 text-right">
                  <button type="button" title="Remove"
                    onclick="nkCartRemove({{ product.cart_id }}, '{{ language|default('en-gb') }}')"
                    class="p-2 text-slate-300 hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined">delete</span>
                  </button>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="mt-4 flex items-center justify-between">
        <a href="{{ continue|default(home|default('/')) }}" class="flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-primary no-underline transition-colors">
          <span class="material-symbols-outlined text-sm">arrow_back</span> Continue Shopping
        </a>
      </div>
    </div>

    {# Order summary #}
    <div class="lg:col-span-4">
      <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm sticky top-24">
        <h2 class="font-bold text-slate-900 text-lg mb-6">Order Summary</h2>
        <dl class="space-y-3 mb-6">
          {% for total in totals|default([]) %}
            <div class="flex justify-between {{ loop.last ? 'border-t border-slate-200 pt-3 mt-3' : '' }}">
              <dt class="{{ loop.last ? 'font-bold text-slate-900' : 'text-slate-500' }}">{{ total.title }}</dt>
              <dd class="{{ loop.last ? 'font-bold text-primary text-lg' : 'font-medium text-slate-900' }}">{{ total.text }}</dd>
            </div>
          {% else %}
            <div class="flex justify-between">
              <dt class="text-slate-500">Subtotal</dt>
              <dd class="font-medium text-slate-900">—</dd>
            </div>
          {% endfor %}
        </dl>

        <a href="{{ checkout|default('#') }}" class="flex items-center justify-center gap-2 w-full bg-primary text-white rounded-xl py-4 font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 no-underline">
          <span class="material-symbols-outlined">lock</span> Proceed to Checkout
        </a>
        <p class="text-center text-xs text-slate-400 mt-3 flex items-center justify-center gap-1">
          <span class="material-symbols-outlined text-sm">verified_user</span> Secure SSL checkout
        </p>
      </div>
    </div>

  </div>
  {% else %}
    <div class="flex flex-col items-center justify-center py-24 text-center bg-white rounded-2xl border border-slate-200">
      <span class="material-symbols-outlined text-7xl text-slate-200 mb-4">shopping_bag</span>
      <h2 class="text-xl font-bold text-slate-900 mb-2">Your cart is empty</h2>
      <p class="text-slate-500 mb-6">Looks like you haven't added anything yet.</p>
      <a href="{{ continue|default(home|default('/')) }}" class="px-6 py-3 bg-primary text-white rounded-xl font-semibold hover:bg-primary/90 transition-colors no-underline">Start Shopping</a>
    </div>
  {% endif %}

</main>

{{ footer }}
