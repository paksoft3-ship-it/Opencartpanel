{# NovaKur Base: Product review list (Tailwind) #}
{% if reviews %}
  <div class="space-y-5">
    {% for review in reviews %}
      <div class="border border-slate-200 rounded-xl p-5">
        <div class="flex items-start justify-between gap-4 mb-3">
          <div>
            <p class="font-bold text-slate-900">{{ review.author }}</p>
            <p class="text-xs text-slate-400 mt-0.5">{{ review.date_added }}</p>
          </div>
          <div class="flex text-yellow-400 shrink-0">
            {% for i in 1..5 %}
              <span class="material-symbols-outlined text-[18px]" style="font-variation-settings:'FILL' {{ review.rating >= i ? '1' : '0' }}">star</span>
            {% endfor %}
          </div>
        </div>
        <p class="text-slate-600 text-sm leading-relaxed">{{ review.text }}</p>
      </div>
    {% endfor %}
  </div>
  {% if pagination is defined and pagination %}
    <div class="mt-6 flex justify-center">{{ pagination|raw }}</div>
  {% endif %}
{% else %}
  <p class="text-slate-400 text-sm text-center py-8">{{ text_no_results|default('No reviews yet. Be the first to write one!') }}</p>
{% endif %}
