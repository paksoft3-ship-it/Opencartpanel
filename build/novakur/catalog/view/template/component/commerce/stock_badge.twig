{# NovaKur Base commerce component: stock_badge #}
{% set stock_status_value = stock_status|default('Availability Unknown') %}
{% set stock_status_lower = stock_status_value|lower %}
{% set quantity_value = quantity is defined ? quantity : null %}

{% set is_in_stock = (quantity_value is not null and quantity_value > 0) or ('in stock' in stock_status_lower) %}
{% set is_out_of_stock = (quantity_value is not null and quantity_value == 0) or ('out of stock' in stock_status_lower) %}

{% if is_in_stock %}
  <span class="inline-flex items-center gap-1 text-xs font-bold text-green-700 bg-green-50 border border-green-200 rounded-full px-2.5 py-0.5">
    <span class="material-symbols-outlined text-[14px]">check_circle</span>{{ stock_status_value }}
  </span>
{% elseif is_out_of_stock %}
  <span class="inline-flex items-center gap-1 text-xs font-bold text-red-600 bg-red-50 border border-red-200 rounded-full px-2.5 py-0.5">
    <span class="material-symbols-outlined text-[14px]">cancel</span>{{ stock_status_value }}
  </span>
{% else %}
  <span class="inline-flex items-center gap-1 text-xs font-bold text-slate-600 bg-slate-100 border border-slate-200 rounded-full px-2.5 py-0.5">
    <span class="material-symbols-outlined text-[14px]">inventory</span>{{ stock_status_value }}
  </span>
{% endif %}
