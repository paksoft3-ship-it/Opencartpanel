{# NovaKur Base section component: upsell_grid #}
{% if products is defined and products %}
<section class="py-10">
  <div class="flex items-center gap-2 mb-5">
    <span class="material-symbols-outlined text-primary">shopping_bag</span>
    <h2 class="text-2xl font-black text-slate-900">{{ heading|default('Frequently Bought Together') }}</h2>
  </div>

  <div class="grid grid-cols-2 gap-4">
    {% for p in products|slice(0, 4) %}
      <div class="bg-white rounded-xl border border-slate-200 p-3 flex gap-3 items-center hover:border-primary/30 transition-all">
        <a href="{{ p.href|default('#') }}" class="no-underline shrink-0">
          {% if p.thumb is defined and p.thumb %}
            <img src="{{ p.thumb|default('') }}" alt="{{ p.name|default('Product') }}" class="w-16 h-16 rounded-lg object-cover bg-slate-100"/>
          {% else %}
            <div class="w-16 h-16 rounded-lg bg-slate-100"></div>
          {% endif %}
        </a>

        <div class="min-w-0 flex-1">
          <a href="{{ p.href|default('#') }}" class="no-underline">
            <p class="text-xs font-bold text-slate-900 line-clamp-2">{{ p.name|default('Product') }}</p>
          </a>
          <p class="text-xs font-semibold text-primary mt-0.5">{{ p.special|default(p.price|default('')) }}</p>
        </div>

        <button type="button" class="ml-auto p-1.5 bg-primary/10 text-primary rounded-lg hover:bg-primary hover:text-white transition-colors" aria-label="Add">
          <span class="material-symbols-outlined text-[16px]">add</span>
        </button>
      </div>
    {% endfor %}
  </div>
</section>
{% endif %}
