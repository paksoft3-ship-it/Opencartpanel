{# NovaKur Base section component: blog_preview #}
{% set section_heading = heading|default('From the Blog') %}
{% set article_list = articles|default([]) %}

<section class="py-12">
  <div class="flex items-center justify-between gap-4 mb-6">
    <div>
      <h2 class="text-2xl font-black text-slate-900 mb-2">{{ section_heading }}</h2>
      <p class="text-slate-500 text-sm">Latest stories, ideas, and updates.</p>
    </div>
    <a href="#" class="text-sm font-semibold text-primary hover:text-primary/80 transition-colors no-underline">Read more</a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {% if article_list %}
      {% for article in article_list|slice(0, 3) %}
        <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-md transition-all group">
          <div class="aspect-video bg-slate-100 overflow-hidden">
            {% if article.image is defined and article.image %}
              <img src="{{ article.image|default('') }}" alt="{{ article.title|default('Article') }}" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform"/>
            {% else %}
              <div class="w-full h-full bg-gradient-to-br from-slate-100 to-slate-200"></div>
            {% endif %}
          </div>
          <div class="p-5">
            <p class="text-xs text-slate-400 mb-2">{{ article.date|default('') }}</p>
            <h3 class="font-bold text-slate-900 text-sm mb-2 group-hover:text-primary transition-colors">{{ article.title|default('Article title') }}</h3>
            <p class="text-xs text-slate-500 line-clamp-3 mb-3">{{ article.excerpt|default('') }}</p>
            <a href="{{ article.href|default('#') }}" class="text-xs font-semibold text-primary flex items-center gap-1 no-underline">
              Read more
              <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
            </a>
          </div>
        </article>
      {% endfor %}
    {% else %}
      {% set demo_articles = [
        {
          title: 'Top 10 Tech Gadgets of 2025',
          excerpt: 'Discover this year\'s most innovative gadgets that blend performance, design, and everyday convenience.',
          href: '#',
          image: '',
          date: 'Jan 12, 2025'
        },
        {
          title: 'Style Guide: Summer Essentials',
          excerpt: 'Build a timeless summer wardrobe with curated essentials that balance comfort and minimal style.',
          href: '#',
          image: '',
          date: 'Feb 03, 2025'
        },
        {
          title: 'How to Choose the Perfect Gift',
          excerpt: 'A practical checklist to help you pick thoughtful gifts for every personality and occasion.',
          href: '#',
          image: '',
          date: 'Mar 01, 2025'
        }
      ] %}
      {% for article in demo_articles %}
        <article class="bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-md transition-all group">
          <div class="aspect-video bg-slate-100 overflow-hidden">
            <div class="w-full h-full bg-gradient-to-br from-slate-100 to-slate-200"></div>
          </div>
          <div class="p-5">
            <p class="text-xs text-slate-400 mb-2">{{ article.date|default('') }}</p>
            <h3 class="font-bold text-slate-900 text-sm mb-2 group-hover:text-primary transition-colors">{{ article.title|default('Article title') }}</h3>
            <p class="text-xs text-slate-500 line-clamp-3 mb-3">{{ article.excerpt|default('') }}</p>
            <a href="{{ article.href|default('#') }}" class="text-xs font-semibold text-primary flex items-center gap-1 no-underline">
              Read more
              <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
            </a>
          </div>
        </article>
      {% endfor %}
    {% endif %}
  </div>
</section>
