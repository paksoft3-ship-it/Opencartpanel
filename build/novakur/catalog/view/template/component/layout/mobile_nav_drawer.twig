{# NovaKur Base layout component: mobile_nav_drawer #}
<div id="nk-drawer-backdrop" class="fixed inset-0 bg-black/50 z-40 hidden"></div>

<div id="nk-mobile-drawer" class="fixed top-0 left-0 h-full w-72 bg-white z-50 shadow-2xl transform -translate-x-full transition-transform duration-300 flex flex-col">
  <div class="flex items-center justify-between px-4 py-4 border-b border-slate-200">
    <a href="{{ home|default('/') }}" class="text-base font-black text-slate-900 no-underline">Menu</a>
    <button type="button" onclick="nkCloseDrawer()" class="p-2 text-slate-500 hover:text-primary transition-colors">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>

  <div class="flex-1 overflow-y-auto p-4 space-y-2">
    {% for category in categories|default([]) %}
      {% if category.children is defined and category.children %}
        <details class="group border border-slate-200 rounded-xl">
          <summary class="list-none cursor-pointer flex items-center justify-between px-3 py-2.5 text-sm font-semibold text-slate-800 hover:text-primary transition-colors">
            <span>{{ category.name|default(category.text|default('')) }}</span>
            <span class="material-symbols-outlined text-[18px] text-slate-400 group-open:rotate-180 transition-transform">expand_more</span>
          </summary>
          <div class="px-3 pb-3 pt-1 space-y-1 border-t border-slate-100">
            <a href="{{ category.href|default('#') }}" class="block py-1.5 text-sm font-medium text-slate-600 hover:text-primary transition-colors no-underline">All {{ category.name|default(category.text|default('Category')) }}</a>
            {% for child in category.children %}
              <a href="{{ child.href|default('#') }}" class="block py-1.5 text-sm text-slate-600 hover:text-primary transition-colors no-underline">{{ child.name|default('') }}</a>
            {% endfor %}
          </div>
        </details>
      {% else %}
        <a href="{{ category.href|default('#') }}" class="flex items-center justify-between px-3 py-2.5 border border-slate-200 rounded-xl text-sm font-semibold text-slate-800 hover:text-primary transition-colors no-underline">
          <span>{{ category.name|default(category.text|default('')) }}</span>
          <span class="material-symbols-outlined text-[18px] text-slate-400">chevron_right</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>

  <div class="border-t border-slate-200 px-4 py-3 grid grid-cols-4 gap-2">
    <a href="{{ home|default('/') }}" class="flex flex-col items-center justify-center gap-1 py-2 text-slate-600 hover:text-primary transition-colors no-underline">
      <span class="material-symbols-outlined text-[20px]">home</span><span class="text-[11px] font-medium">Home</span>
    </a>
    <a href="{{ account|default(login|default('#')) }}" class="flex flex-col items-center justify-center gap-1 py-2 text-slate-600 hover:text-primary transition-colors no-underline">
      <span class="material-symbols-outlined text-[20px]">person</span><span class="text-[11px] font-medium">Account</span>
    </a>
    <a href="{{ wishlist|default('#') }}" class="flex flex-col items-center justify-center gap-1 py-2 text-slate-600 hover:text-primary transition-colors no-underline">
      <span class="material-symbols-outlined text-[20px]">favorite</span><span class="text-[11px] font-medium">Wishlist</span>
    </a>
    <a href="{{ cart|default('#') }}" class="flex flex-col items-center justify-center gap-1 py-2 text-slate-600 hover:text-primary transition-colors no-underline">
      <span class="material-symbols-outlined text-[20px]">shopping_bag</span><span class="text-[11px] font-medium">Cart</span>
    </a>
  </div>
</div>
