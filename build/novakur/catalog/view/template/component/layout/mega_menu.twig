{# NovaKur Base layout component: mega_menu #}
{% set menu_category = category|default({}) %}
{% set child_list = menu_category.children|default([]) %}
{% set featured = menu_category.featured_product|default({}) %}
{% set open_state = is_open|default(false) %}

<div class="absolute top-full left-0 w-full bg-white border-t border-slate-200 shadow-xl z-50 {{ open_state ? 'block' : 'hidden group-hover:block' }}">
  <div class="grid grid-cols-4 gap-8 max-w-7xl mx-auto px-8 py-8">
    <div class="col-span-3 grid grid-cols-3 gap-8">
      {% for col in 1..3 %}
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-3">{{ menu_category.name|default('Category') }}</p>
          <div>
            {% for child in child_list %}
              <a href="{{ child.href|default('#') }}" class="flex items-center gap-2 text-sm text-slate-600 hover:text-primary transition-colors no-underline py-1">
                <span class="material-symbols-outlined text-[14px]">chevron_right</span>
                {{ child.name|default('Subcategory') }}
              </a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div>
      {% if featured %}
        <a href="{{ featured.href|default('#') }}" class="block bg-white rounded-2xl border border-slate-200 p-4 shadow-sm no-underline hover:border-primary/30 transition-colors">
          <span class="inline-flex items-center bg-primary/10 text-primary text-[10px] font-bold uppercase px-2 py-1 rounded-full mb-3">Featured</span>
          <div class="rounded-xl overflow-hidden aspect-square bg-slate-100 mb-2">
            {% if featured.thumb is defined and featured.thumb %}
              <img src="{{ featured.thumb|default('') }}" alt="{{ featured.name|default('Featured Product') }}" class="w-full h-full object-cover"/>
            {% endif %}
          </div>
          <p class="text-sm font-bold text-slate-900">{{ featured.name|default('Featured Product') }}</p>
          <p class="text-sm text-primary font-bold">{{ featured.price|default('') }}</p>
        </a>
      {% endif %}
    </div>
  </div>
</div>
