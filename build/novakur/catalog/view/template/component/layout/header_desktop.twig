{# NovaKur Base layout component: header_desktop (Tailwind) #}

{% include 'extension/novakur/catalog/view/template/component/layout/announcement_bar.twig' with {
  message: 'Free express shipping on orders over $150 &nbsp;|&nbsp; Summer Sale - save up to 40% with code <strong>NOVA40</strong>',
  link: '',
  bg_color: 'bg-primary'
} only %}

{# Main Header #}
<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">

    {# Top row: Logo / Search / Icons #}
    <div class="flex items-center justify-between h-20 gap-8">

      <button onclick="nkOpenDrawer()" class="lg:hidden p-2 text-slate-600 hover:text-primary">
        <span class="material-symbols-outlined">menu</span>
      </button>

      {# Logo #}
      <a href="{{ home|default('/') }}" class="flex items-center gap-3 shrink-0 no-underline">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg">
          <span class="material-symbols-outlined">layers</span>
        </div>
        <span class="text-xl font-bold tracking-tight text-slate-900">{{ store_name|default('Store') }}</span>
      </a>

      {# Search #}
      <div class="hidden md:flex flex-1 max-w-2xl">
        <div class="relative w-full group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
            <span class="material-symbols-outlined text-[20px]">search</span>
          </div>
          <input class="w-full bg-slate-100 border-none rounded-2xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-primary/20 text-sm outline-none" placeholder="Search for products, brands and more..." type="text"/>
        </div>
      </div>

      {# User Actions #}
      <div class="flex items-center gap-2">
        <a href="{{ account|default('#') }}" class="p-2.5 rounded-xl hover:bg-slate-100 transition-colors text-slate-700 no-underline" title="Account">
          <span class="material-symbols-outlined">person</span>
        </a>
        <a href="{{ wishlist|default('#') }}" class="p-2.5 rounded-xl hover:bg-slate-100 transition-colors text-slate-700 relative no-underline" title="Wishlist">
          <span class="material-symbols-outlined">favorite</span>
        </a>
        <a href="{{ shopping_cart|default('#') }}" class="flex items-center gap-2 px-4 py-2.5 bg-slate-900 text-white rounded-xl font-semibold text-sm hover:bg-slate-800 transition-all shadow-sm no-underline" title="Cart">
          <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
          <span>Cart{% if cart_count is defined and cart_count > 0 %} ({{ cart_count }}){% endif %}</span>
        </a>
      </div>
    </div>

    {# Bottom row: Navigation #}
    <nav class="flex items-center gap-8 h-12 border-t border-slate-100 overflow-x-auto no-scrollbar">
      <a class="text-sm font-semibold text-primary whitespace-nowrap no-underline" href="{{ home|default('/') }}">Home</a>
      {% if menu_items %}
        {% for item in menu_items %}
          <div class="relative group">
            <a class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors whitespace-nowrap no-underline" href="{{ item.href|default('#') }}">{{ item.text|default('Category') }}</a>
            {% if item.children is defined and item.children %}
              {% include 'extension/novakur/catalog/view/template/component/layout/mega_menu.twig' with { category: item } only %}
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        <a class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors whitespace-nowrap no-underline" href="{{ home|default('/') }}">Shop</a>
      {% endif %}
    </nav>

  </div>
</header>
