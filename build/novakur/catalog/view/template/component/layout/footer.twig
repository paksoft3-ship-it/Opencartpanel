{# NovaKur Base layout component: footer (Tailwind) #}
<footer class="bg-slate-900 text-slate-400 mt-16" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-10">

      {# Brand column #}
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center text-white">
            <span class="material-symbols-outlined text-[20px]">layers</span>
          </div>
          <span class="text-white font-bold text-lg">{{ store_name|default('Store') }}</span>
        </div>
        <p class="text-sm leading-relaxed">Your trusted online store for quality products at great prices.</p>
      </div>

      {# Links columns #}
      <div>
        <h4 class="text-white font-bold text-sm mb-4 uppercase tracking-wider">Shop</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#" class="hover:text-white transition-colors no-underline">New Arrivals</a></li>
          <li><a href="#" class="hover:text-white transition-colors no-underline">Best Sellers</a></li>
          <li><a href="#" class="hover:text-white transition-colors no-underline">Sale</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4 uppercase tracking-wider">Support</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#" class="hover:text-white transition-colors no-underline">Contact Us</a></li>
          <li><a href="#" class="hover:text-white transition-colors no-underline">Returns</a></li>
          <li><a href="#" class="hover:text-white transition-colors no-underline">Shipping Info</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm mb-4 uppercase tracking-wider">Company</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="#" class="hover:text-white transition-colors no-underline">About Us</a></li>
          <li><a href="#" class="hover:text-white transition-colors no-underline">Privacy Policy</a></li>
          <li><a href="#" class="hover:text-white transition-colors no-underline">Terms</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 pt-6 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
      <p>&copy; {{ 'now'|date('Y') }} {{ store_name|default('Store') }}. All rights reserved.</p>
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-[18px]">lock</span>
        <span>Secure Checkout</span>
      </div>
    </div>
  </div>
</footer>
