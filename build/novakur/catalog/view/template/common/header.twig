<!DOCTYPE html>
<html dir="{{ direction }}" lang="{{ lang }}">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
  <title>{{ title }}</title>
  <base href="{{ base }}"/>
  {% if description %}<meta name="description" content="{{ description }}"/>{% endif %}
  {% if keywords %}<meta name="keywords" content="{{ keywords }}"/>{% endif %}

  {# Tailwind CSS + Google Fonts + Material Symbols #}
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            "primary": "{{ novakur_primary_color|default('#2463eb') }}",
            "background-light": "#f6f6f8",
          },
          fontFamily: { "display": ["Inter", "sans-serif"] },
          borderRadius: {
            "DEFAULT": "0.25rem", "lg": "0.5rem",
            "xl": "0.75rem", "2xl": "1rem", "full": "9999px"
          },
        },
      },
    }
  </script>

  {# jQuery — required by OC's JS modules #}
  <script src="catalog/view/javascript/jquery/jquery-3.7.1.min.js" type="text/javascript"></script>
  <script src="catalog/view/javascript/common.js" type="text/javascript"></script>

  {# Extension-injected styles and scripts #}
  {% for style in styles %}
    <link href="{{ style.href }}" type="text/css" rel="{{ style.rel }}" media="{{ style.media }}"/>
  {% endfor %}
  {% for script in scripts %}
    <script src="{{ script.href }}" type="text/javascript"></script>
  {% endfor %}
  {% for link in links %}
    <link href="{{ link.href }}" rel="{{ link.rel }}"/>
  {% endfor %}

  <style>
    :root {
      --nk-primary:          {{ novakur_primary_color|default('#2463eb') }};
      --nk-color-primary:    {{ novakur_primary_color|default('#2563eb') }};
      --nk-secondary:        {{ novakur_secondary_color|default('#1e3a8a') }};
      --nk-color-deep:       {{ novakur_secondary_color|default('#1e3a8a') }};
      --nk-container-width:  {{ novakur_container_width|default(1280) }}px;
      --nk-font-base:        '{{ novakur_base_font|default('Inter') }}', sans-serif;
    }
    body { font-family: var(--nk-font-base, 'Inter', sans-serif); }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
</head>
<body class="bg-background-light text-slate-900 antialiased">

{% include "extension/novakur/catalog/view/template/component/layout/mobile_nav_drawer.twig" with {
  categories: menu_items|default([]),
  account: account|default("#"),
  wishlist: wishlist|default("#"),
  cart: shopping_cart|default("#"),
  login: login|default("#"),
  home: home|default("/")
} only %}


<div id="alert" class="fixed top-4 right-4 z-[100]"></div>

{# Announcement bar #}
<div class="bg-primary text-white text-xs font-medium py-2 px-4 flex justify-center items-center gap-4">
  <span>Free express shipping on orders over $150</span>
  <span class="hidden md:inline text-white/60">|</span>
  <span class="hidden md:inline">Summer Sale — save up to 40% with code NOVA40</span>
</div>

{# Main sticky header #}
<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
  <div class="max-w-7xl mx-auto px-4 lg:px-8">

    {# Top row: Logo / Search / Icons #}
    <div class="flex items-center justify-between h-20 gap-8">

      <button onclick="nkOpenDrawer()" class="lg:hidden p-2 text-slate-600 hover:text-primary">
  <span class="material-symbols-outlined">menu</span>
</button>

{# Logo #}
      <a href="{{ home|default('/') }}" class="flex items-center gap-3 shrink-0 no-underline">
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-lg">
          <span class="material-symbols-outlined">layers</span>
        </div>
        <span class="text-xl font-bold tracking-tight text-slate-900">{{ name|default('Store') }}</span>
      </a>

      {# Search bar #}
      <div class="hidden md:flex flex-1 max-w-2xl">
        <form action="index.php" method="get" class="relative w-full">
          <input type="hidden" name="route" value="product/search"/>
          <input type="hidden" name="language" value="{{ lang|default('en-gb') }}"/>
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
            <span class="material-symbols-outlined text-[20px]">search</span>
          </div>
          <input name="search" type="text" autocomplete="off"
            class="w-full bg-slate-100 border-none rounded-2xl py-3 pl-12 pr-12 focus:ring-2 focus:ring-primary/20 text-sm outline-none"
            placeholder="Search for products, brands and more..."/>
          <button type="submit" class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-400 hover:text-primary transition-colors">
            <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
          </button>
        </form>
      </div>

      {# User action icons #}
      <div class="flex items-center gap-2">
        <a href="{{ account|default('#') }}" class="p-2.5 rounded-xl hover:bg-slate-100 transition-colors text-slate-700 no-underline" title="Account">
          <span class="material-symbols-outlined">person</span>
        </a>
        <a href="{{ wishlist|default('#') }}" class="p-2.5 rounded-xl hover:bg-slate-100 transition-colors text-slate-700 no-underline" title="Wishlist">
          <span class="material-symbols-outlined">favorite</span>
        </a>
        <a href="{{ shopping_cart|default('#') }}" class="relative flex items-center gap-2 px-4 py-2.5 bg-slate-900 text-white rounded-xl font-semibold text-sm hover:bg-slate-800 transition-all shadow-sm no-underline" title="Cart">
          <span class="material-symbols-outlined text-[20px]">shopping_bag</span>
          <span>Cart</span>
          <span id="nk-cart-count" class="absolute -top-1.5 -right-1.5 min-w-[18px] h-[18px] bg-primary text-white text-[10px] font-black rounded-full flex items-center justify-center px-1 {{ cart_count is defined and cart_count > 0 ? '' : 'hidden' }}">{{ cart_count is defined and cart_count > 0 ? cart_count : '' }}</span>
        </a>
      </div>
    </div>

    {# Bottom row: Category navigation #}
    <nav class="flex items-center gap-8 h-12 border-t border-slate-100 overflow-x-auto no-scrollbar">
      <a class="text-sm font-semibold text-primary whitespace-nowrap no-underline" href="{{ home|default('/') }}">Home</a>
      {% if menu_items %}
        {% for item in menu_items %}
          <a class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors whitespace-nowrap no-underline" href="{{ item.href }}">{{ item.text }}</a>
        {% endfor %}
      {% else %}
        <a class="text-sm font-semibold text-slate-600 hover:text-primary transition-colors whitespace-nowrap no-underline" href="{{ home|default('/') }}">Shop</a>
      {% endif %}
    </nav>

  </div>
</header>

<script src="{{ HTTP_SERVER }}extension/novakur/catalog/view/assets/dist/js/novakur.js"></script>
