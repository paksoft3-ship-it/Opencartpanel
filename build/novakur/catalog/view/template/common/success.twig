{# NovaKur Base: Success page (Tailwind) #}
{{ header }}

<main class="max-w-7xl mx-auto px-4 lg:px-8 py-8">
  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}

  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-20 h-20 bg-green-50 rounded-full flex items-center justify-center mb-6">
      <span class="material-symbols-outlined text-green-500 text-4xl">check_circle</span>
    </div>
    <h1 class="text-3xl font-black text-slate-900 mb-3">{{ heading_title|default('Success!') }}</h1>
    <p class="text-slate-500 max-w-md mb-8">{{ text_message|default('')|raw }}</p>
    <a href="{{ continue|default('/') }}" class="flex items-center gap-2 bg-primary text-white rounded-xl px-6 py-3 font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 no-underline">
      <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
      {{ button_continue|default('Continue') }}
    </a>
  </div>
</main>

{{ footer }}
