{# NovaKur Base: Wishlist page (Tailwind) #}
{{ header }}
<main class="max-w-7xl mx-auto px-4 lg:px-8 py-8">
  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}
  <div class="flex flex-col lg:flex-row gap-8">
    <aside class="hidden lg:block w-56 shrink-0">
      <nav class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-4 py-4 border-b border-slate-100"><p class="text-xs font-bold uppercase tracking-wider text-slate-400">My Account</p></div>
        {% for item in [
          { label: 'Dashboard', href: account|default('#'), icon: 'dashboard', key: 'account' },
          { label: 'Orders', href: order|default('#'), icon: 'receipt_long', key: 'order' },
          { label: 'Wishlist', href: wishlist|default('#'), icon: 'favorite', key: 'wishlist' },
          { label: 'Address Book', href: address|default('#'), icon: 'location_on', key: 'address' },
          { label: 'Logout', href: logout|default('#'), icon: 'logout', key: 'logout' }
        ] %}
          <a href="{{ item.href }}" class="flex items-center gap-3 px-4 py-3 text-sm font-medium no-underline transition-colors {{ item.key == 'wishlist' ? 'text-primary bg-primary/5' : 'text-slate-600 hover:text-primary hover:bg-slate-50' }}">
            <span class="material-symbols-outlined text-[18px]">{{ item.icon }}</span>{{ item.label }}
          </a>
        {% endfor %}
      </nav>
    </aside>
    <section class="flex-1 min-w-0">
      <h1 class="text-2xl font-black text-slate-900 mb-6">{{ heading_title|default('Wishlist') }}</h1>
      {% set wishlist_products = products|default([]) %}
      {% if wishlist_products %}
        <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-5">
          {% for product in wishlist_products %}
            <div id="wishlist-item-{{ product.product_id }}" class="group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:shadow-lg transition-all">
              <a href="{{ product.href|default('#') }}" class="block aspect-square bg-slate-100 overflow-hidden no-underline">
                {% if product.thumb is defined and product.thumb %}
                  <img src="{{ product.thumb }}" alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"/>
                {% else %}
                  <div class="w-full h-full flex items-center justify-center"><span class="material-symbols-outlined text-5xl text-slate-300">image</span></div>
                {% endif %}
              </a>
              <div class="p-4">
                <a href="{{ product.href|default('#') }}" class="font-bold text-slate-900 text-sm hover:text-primary no-underline block mb-1">{{ product.name }}</a>
                <p class="font-bold text-primary text-sm mb-1">{{ product.special is defined and product.special ? product.special : product.price|default('') }}</p>
                <p class="text-xs mb-3 {{ 'out' in (product.stock|default(''))|lower ? 'text-red-500' : 'text-green-600' }}">{{ product.stock|default('') }}</p>
                <div class="flex gap-2">
                  <button type="button" onclick="nkQuickAdd({{ product.product_id }}, '{{ language|default('en-gb') }}')"
                    class="flex-1 text-center text-xs font-bold bg-primary text-white rounded-lg py-2 hover:bg-primary/90 transition-all">Add to Cart</button>
                  <button type="button" title="Remove from wishlist"
                    onclick="nkWishlistRemove({{ product.product_id }}, '{{ language|default('en-gb') }}', '{{ customer_token|default('') }}')"
                    class="p-2 rounded-lg border border-slate-200 text-slate-400 hover:text-red-500 transition-colors">
                    <span class="material-symbols-outlined text-[16px]">delete</span></button>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="flex flex-col items-center justify-center py-24 bg-white rounded-2xl border border-slate-200 text-center">
          <span class="material-symbols-outlined text-7xl text-slate-200 mb-4">favorite</span>
          <h2 class="text-xl font-bold text-slate-900 mb-2">Your wishlist is empty</h2>
          <a href="{{ home|default('/') }}" class="px-6 py-3 bg-primary text-white rounded-xl font-semibold hover:bg-primary/90 no-underline mt-4">Start Shopping</a>
        </div>
      {% endif %}
    </section>
  </div>
</main>
{{ footer }}