{# NovaKur Base: Change password (Tailwind) #}
{{ header }}

<main class="max-w-7xl mx-auto px-4 lg:px-8 py-8">
  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}

  <div class="flex flex-col lg:flex-row gap-8">

    {# Sidebar nav #}
    <aside class="w-full lg:w-56 shrink-0">
      <nav class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-4 py-4 border-b border-slate-100">
          <p class="text-xs font-bold uppercase tracking-wider text-slate-400">My Account</p>
        </div>
        {% set account_links = [
          { label: 'Dashboard', href: account|default('#'), icon: 'dashboard', active: false },
          { label: 'Orders', href: order|default('#'), icon: 'receipt_long', active: false },
          { label: 'Wishlist', href: wishlist|default('#'), icon: 'favorite', active: false },
          { label: 'Address Book', href: address|default('#'), icon: 'location_on', active: false },
          { label: 'Edit Details', href: edit|default('#'), icon: 'edit', active: false },
          { label: 'Change Password', href: password|default('#'), icon: 'lock', active: true },
          { label: 'Logout', href: logout|default('#'), icon: 'logout', active: false }
        ] %}
        {% for link in account_links %}
          <a href="{{ link.href }}" class="flex items-center gap-3 px-4 py-3 text-sm font-medium {{ link.active ? 'text-primary bg-primary/5' : 'text-slate-600 hover:text-primary hover:bg-slate-50' }} transition-colors no-underline">
            <span class="material-symbols-outlined text-[18px]">{{ link.icon }}</span>
            {{ link.label }}
          </a>
        {% endfor %}
      </nav>
    </aside>

    {# Main content #}
    <section class="flex-1 min-w-0">
      <h1 class="text-2xl font-black text-slate-900 mb-6">{{ heading_title|default('Change Password') }}</h1>

      {% if error_warning is defined and error_warning %}
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">{{ error_warning }}</div>
      {% endif %}

      <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm max-w-lg">
        <form action="{{ action|default('#') }}" method="post" class="space-y-5">
          <div>
            <label for="input-password" class="block text-sm font-semibold text-slate-700 mb-1.5">New Password <span class="text-red-500">*</span></label>
            <input type="password" id="input-password" name="password" placeholder="New password"
              class="w-full rounded-xl border {{ error_password is defined and error_password ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
            {% if error_password is defined and error_password %}<p class="text-red-500 text-xs mt-1">{{ error_password }}</p>{% endif %}
          </div>
          <div>
            <label for="input-confirm" class="block text-sm font-semibold text-slate-700 mb-1.5">Confirm Password <span class="text-red-500">*</span></label>
            <input type="password" id="input-confirm" name="confirm" placeholder="Repeat new password"
              class="w-full rounded-xl border {{ error_confirm is defined and error_confirm ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
            {% if error_confirm is defined and error_confirm %}<p class="text-red-500 text-xs mt-1">{{ error_confirm }}</p>{% endif %}
          </div>
          <div class="pt-2">
            <button type="submit" class="bg-primary text-white rounded-xl px-8 py-3 font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
              {{ button_continue|default('Update Password') }}
            </button>
          </div>
        </form>
      </div>
    </section>

  </div>
</main>

{{ footer }}
