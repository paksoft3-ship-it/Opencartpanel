{# NovaKur Base: Forgotten password (Tailwind) #}
{{ header }}

<main class="max-w-7xl mx-auto px-4 lg:px-8 py-12">
  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}

  <div class="max-w-md mx-auto">
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
      <div class="text-center mb-8">
        <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <span class="material-symbols-outlined text-primary text-3xl">lock_reset</span>
        </div>
        <h1 class="text-2xl font-black text-slate-900">{{ heading_title|default('Forgot Password') }}</h1>
        <p class="text-slate-500 text-sm mt-1">Enter your email and we'll send a reset link</p>
      </div>

      {% if error_warning is defined and error_warning %}
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">{{ error_warning }}</div>
      {% endif %}

      <form action="{{ action|default('#') }}" method="post" class="space-y-4">
        <div>
          <label for="input-email" class="block text-sm font-semibold text-slate-700 mb-1.5">Email Address</label>
          <input type="email" id="input-email" name="email" value="{{ email|default('') }}" placeholder="name@example.com"
            class="w-full rounded-xl border {{ error_email is defined and error_email ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
          {% if error_email is defined and error_email %}<p class="text-red-500 text-xs mt-1">{{ error_email }}</p>{% endif %}
        </div>
        <button type="submit" class="w-full bg-primary text-white rounded-xl py-3 font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
          {{ button_continue|default('Send Reset Link') }}
        </button>
      </form>

      <p class="text-center text-sm text-slate-500 mt-6">
        Remember your password?
        <a href="{{ login|default('#') }}" class="text-primary font-semibold hover:underline no-underline">Sign in</a>
      </p>
    </div>
  </div>
</main>

{{ footer }}
