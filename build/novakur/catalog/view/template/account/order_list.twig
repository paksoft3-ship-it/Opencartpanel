{# NovaKur Base: Order list page (Tailwind) #}
{{ header }}
<main class="max-w-7xl mx-auto px-4 lg:px-8 py-8">
  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig' with { breadcrumbs: breadcrumbs|default([]) } only %}
  <div class="flex flex-col lg:flex-row gap-8">
    <aside class="hidden lg:block w-56 shrink-0">
      <nav class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-4 py-4 border-b border-slate-100"><p class="text-xs font-bold uppercase tracking-wider text-slate-400">My Account</p></div>
        {% for item in [
          { label: 'Dashboard', href: account|default('#'), icon: 'dashboard', key: 'account' },
          { label: 'Orders', href: order|default('#'), icon: 'receipt_long', key: 'order' },
          { label: 'Wishlist', href: wishlist|default('#'), icon: 'favorite', key: 'wishlist' },
          { label: 'Address Book', href: address|default('#'), icon: 'location_on', key: 'address' },
          { label: 'Logout', href: logout|default('#'), icon: 'logout', key: 'logout' }
        ] %}
          <a href="{{ item.href }}" class="flex items-center gap-3 px-4 py-3 text-sm font-medium no-underline transition-colors {{ item.key == 'order' ? 'text-primary bg-primary/5' : 'text-slate-600 hover:text-primary hover:bg-slate-50' }}">
            <span class="material-symbols-outlined text-[18px]">{{ item.icon }}</span>{{ item.label }}
          </a>
        {% endfor %}
      </nav>
    </aside>
    <section class="flex-1 min-w-0">
      <h1 class="text-2xl font-black text-slate-900 mb-6">{{ heading_title|default('Order History') }}</h1>
      {% if orders|default([]) %}
        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
          <table class="w-full text-left">
            <thead class="border-b border-slate-200 bg-slate-50">
              <tr>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Order ID</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Status</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Total</th>
                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-slate-500">Date</th>
                <th class="px-6 py-4 w-24"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {% for order_item in orders %}
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-bold text-slate-900">#{{ order_item.order_id }}</td>
                  <td class="px-6 py-4"><span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-primary/10 text-primary">{{ order_item.status|default('Pending') }}</span></td>
                  <td class="px-6 py-4 font-medium text-slate-900">{{ order_item.total|default('') }}</td>
                  <td class="px-6 py-4 text-slate-500 text-sm">{{ order_item.date_added|default('') }}</td>
                  <td class="px-6 py-4">
                    <a href="{{ order_item.view|default('#') }}" class="text-sm font-semibold text-primary hover:underline no-underline">View</a>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        {% if pagination is defined and pagination %}
          <div class="mt-6 flex justify-center">{{ pagination|raw }}</div>
        {% endif %}
      {% else %}
        <div class="flex flex-col items-center justify-center py-24 bg-white rounded-2xl border border-slate-200 text-center">
          <span class="material-symbols-outlined text-7xl text-slate-200 mb-4">receipt_long</span>
          <h2 class="text-xl font-bold text-slate-900 mb-2">No orders yet</h2>
          <a href="{{ home|default('/') }}" class="px-6 py-3 bg-primary text-white rounded-xl font-semibold hover:bg-primary/90 no-underline mt-4">Start Shopping</a>
        </div>
      {% endif %}
    </section>
  </div>
</main>
{{ footer }}
