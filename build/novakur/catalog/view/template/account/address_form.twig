{# NovaKur Base: Add/Edit address form (Tailwind) #}
{{ header }}

<main class="max-w-7xl mx-auto px-4 lg:px-8 py-8">
  {% include 'extension/novakur/catalog/view/template/component/layout/breadcrumb.twig'
     with { breadcrumbs: breadcrumbs|default([]) } only %}

  <div class="flex flex-col lg:flex-row gap-8">

    {# Sidebar nav #}
    <aside class="w-full lg:w-56 shrink-0">
      <nav class="bg-white rounded-2xl border border-slate-200 overflow-hidden">
        <div class="px-4 py-4 border-b border-slate-100">
          <p class="text-xs font-bold uppercase tracking-wider text-slate-400">My Account</p>
        </div>
        {% set account_links = [
          { label: 'Dashboard',       href: account|default('#'),  icon: 'dashboard',    active: false },
          { label: 'Orders',          href: order|default('#'),    icon: 'receipt_long', active: false },
          { label: 'Wishlist',        href: wishlist|default('#'), icon: 'favorite',     active: false },
          { label: 'Address Book',    href: address|default('#'),  icon: 'location_on',  active: true },
          { label: 'Edit Details',    href: edit|default('#'),     icon: 'edit',         active: false },
          { label: 'Change Password', href: password|default('#'), icon: 'lock',         active: false },
          { label: 'Logout',          href: logout|default('#'),   icon: 'logout',       active: false }
        ] %}
        {% for link in account_links %}
          <a href="{{ link.href }}"
             class="flex items-center gap-3 px-4 py-3 text-sm font-medium
                    {{ link.active ? 'text-primary bg-primary/5' : 'text-slate-600 hover:text-primary hover:bg-slate-50' }}
                    transition-colors no-underline">
            <span class="material-symbols-outlined text-[18px]">{{ link.icon }}</span>
            {{ link.label }}
          </a>
        {% endfor %}
      </nav>
    </aside>

    <section class="flex-1 min-w-0">
      <h1 class="text-2xl font-black text-slate-900 mb-6">{{ heading_title|default('Address Book') }}</h1>

      {% if error_warning is defined and error_warning %}
        <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">
          {{ error_warning }}
        </div>
      {% endif %}

      <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
        <form action="{{ action|default('#') }}" method="post" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="input-firstname" class="block text-sm font-semibold text-slate-700 mb-1.5">
                First Name <span class="text-red-500">*</span>
              </label>
              <input type="text" id="input-firstname" name="firstname" value="{{ firstname|default('') }}" placeholder="First name"
                class="w-full rounded-xl border {{ error_firstname is defined and error_firstname ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
              {% if error_firstname is defined and error_firstname %}
                <p class="text-red-500 text-xs mt-1">{{ error_firstname }}</p>
              {% endif %}
            </div>

            <div>
              <label for="input-lastname" class="block text-sm font-semibold text-slate-700 mb-1.5">
                Last Name <span class="text-red-500">*</span>
              </label>
              <input type="text" id="input-lastname" name="lastname" value="{{ lastname|default('') }}" placeholder="Last name"
                class="w-full rounded-xl border {{ error_lastname is defined and error_lastname ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
              {% if error_lastname is defined and error_lastname %}
                <p class="text-red-500 text-xs mt-1">{{ error_lastname }}</p>
              {% endif %}
            </div>
          </div>

          <div>
            <label for="input-company" class="block text-sm font-semibold text-slate-700 mb-1.5">Company</label>
            <input type="text" id="input-company" name="company" value="{{ company|default('') }}" placeholder="Company (optional)"
              class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
          </div>

          <div>
            <label for="input-address-1" class="block text-sm font-semibold text-slate-700 mb-1.5">
              Address Line 1 <span class="text-red-500">*</span>
            </label>
            <input type="text" id="input-address-1" name="address_1" value="{{ address_1|default('') }}" placeholder="Street address"
              class="w-full rounded-xl border {{ error_address_1 is defined and error_address_1 ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
            {% if error_address_1 is defined and error_address_1 %}
              <p class="text-red-500 text-xs mt-1">{{ error_address_1 }}</p>
            {% endif %}
          </div>

          <div>
            <label for="input-address-2" class="block text-sm font-semibold text-slate-700 mb-1.5">Address Line 2</label>
            <input type="text" id="input-address-2" name="address_2" value="{{ address_2|default('') }}" placeholder="Apartment, suite, unit (optional)"
              class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="input-city" class="block text-sm font-semibold text-slate-700 mb-1.5">
                City <span class="text-red-500">*</span>
              </label>
              <input type="text" id="input-city" name="city" value="{{ city|default('') }}" placeholder="City"
                class="w-full rounded-xl border {{ error_city is defined and error_city ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
              {% if error_city is defined and error_city %}
                <p class="text-red-500 text-xs mt-1">{{ error_city }}</p>
              {% endif %}
            </div>

            <div>
              <label for="input-postcode" class="block text-sm font-semibold text-slate-700 mb-1.5">
                Postcode <span class="text-red-500">*</span>
              </label>
              <input type="text" id="input-postcode" name="postcode" value="{{ postcode|default('') }}" placeholder="Postcode"
                class="w-full rounded-xl border {{ error_postcode is defined and error_postcode ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 outline-none"/>
              {% if error_postcode is defined and error_postcode %}
                <p class="text-red-500 text-xs mt-1">{{ error_postcode }}</p>
              {% endif %}
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="input-country" class="block text-sm font-semibold text-slate-700 mb-1.5">
                Country <span class="text-red-500">*</span>
              </label>
              <select id="input-country" name="country_id"
                class="w-full rounded-xl border {{ error_country is defined and error_country ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm bg-white focus:ring-2 focus:ring-primary/20 outline-none">
                <option value="">Select country</option>
                {% for country in countries|default([]) %}
                  <option value="{{ country.country_id|default('') }}" {{ country.country_id|default('') == country_id|default('') ? 'selected' : '' }}>
                    {{ country.name|default('') }}
                  </option>
                {% endfor %}
              </select>
              {% if error_country is defined and error_country %}
                <p class="text-red-500 text-xs mt-1">{{ error_country }}</p>
              {% endif %}
            </div>

            <div>
              <label for="input-zone" class="block text-sm font-semibold text-slate-700 mb-1.5">
                Region / State <span class="text-red-500">*</span>
              </label>
              <select id="input-zone" name="zone_id"
                class="w-full rounded-xl border {{ error_zone is defined and error_zone ? 'border-red-400' : 'border-slate-200' }} px-4 py-3 text-sm bg-white focus:ring-2 focus:ring-primary/20 outline-none">
                <option value="">Select region / state</option>
                {% for zone in zones|default([]) %}
                  <option value="{{ zone.zone_id|default('') }}" {{ zone.zone_id|default('') == zone_id|default('') ? 'selected' : '' }}>
                    {{ zone.name|default('') }}
                  </option>
                {% endfor %}
              </select>
              {% if error_zone is defined and error_zone %}
                <p class="text-red-500 text-xs mt-1">{{ error_zone }}</p>
              {% endif %}
            </div>
          </div>

          <div class="pt-1">
            <label class="inline-flex items-center gap-3 text-sm text-slate-700 font-medium cursor-pointer">
              <input type="checkbox" name="default" value="1" {{ default|default(false) ? 'checked' : '' }}
                class="h-4 w-4 rounded border-slate-300 text-primary focus:ring-primary/20"/>
              Default Address
            </label>
          </div>

          <div class="pt-2 flex flex-wrap items-center gap-3">
            <button type="submit"
              class="bg-primary text-white rounded-xl px-8 py-3 font-bold hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
              {{ button_continue|default('Save') }}
            </button>
            <a href="{{ back|default('#') }}"
               class="inline-flex items-center rounded-xl px-6 py-3 border border-slate-200 text-slate-700 font-semibold hover:text-primary hover:border-primary transition-colors no-underline">
              Back
            </a>
          </div>
        </form>
      </div>
    </section>
  </div>
</main>

{{ footer }}
