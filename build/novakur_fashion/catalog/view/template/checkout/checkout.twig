{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}
<div class="nf-container">
  <h1 style="font-family:var(--nf-heading-font);font-size:36px;font-weight:700;padding:40px 0 32px;">Checkout</h1>
  <div style="display:grid;grid-template-columns:1fr 400px;gap:48px;align-items:start;">
    <div>
      <div style="border:1px solid var(--nf-border);margin-bottom:16px;">
        <div style="padding:20px 24px;border-bottom:1px solid var(--nf-border);display:flex;align-items:center;gap:12px;">
          <div style="width:28px;height:28px;border:1px solid var(--nf-border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;">1</div>
          <span style="font-family:var(--nf-heading-font);font-size:18px;font-weight:600;">Your Details</span>
        </div>
        <div style="padding:24px;">
          <div class="nf-form-row"><div class="nf-form-group"><label>First Name *</label><input type="text" name="firstname" required></div><div class="nf-form-group"><label>Last Name *</label><input type="text" name="lastname" required></div></div>
          <div class="nf-form-group"><label>Email *</label><input type="email" name="email" required></div>
          <div class="nf-form-group"><label>Phone</label><input type="tel" name="telephone"></div>
        </div>
      </div>
      <div style="border:1px solid var(--nf-border);margin-bottom:16px;">
        <div style="padding:20px 24px;border-bottom:1px solid var(--nf-border);display:flex;align-items:center;gap:12px;">
          <div style="width:28px;height:28px;border:1px solid var(--nf-border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;">2</div>
          <span style="font-family:var(--nf-heading-font);font-size:18px;font-weight:600;">Shipping Address</span>
        </div>
        <div style="padding:24px;">
          <div class="nf-form-group"><label>Address Line 1 *</label><input type="text" name="address_1" required></div>
          <div class="nf-form-group"><label>Address Line 2</label><input type="text" name="address_2"></div>
          <div class="nf-form-row"><div class="nf-form-group"><label>City *</label><input type="text" name="city" required></div><div class="nf-form-group"><label>Postcode *</label><input type="text" name="postcode" required></div></div>
          <div class="nf-form-group"><label>Country *</label><select name="country_id" class="nf-option-select">{% if countries is defined %}{% for country in countries %}<option value="{{ country.country_id }}">{{ country.name }}</option>{% endfor %}{% endif %}</select></div>
        </div>
      </div>
      <div style="border:1px solid var(--nf-border);">
        <div style="padding:20px 24px;border-bottom:1px solid var(--nf-border);display:flex;align-items:center;gap:12px;">
          <div style="width:28px;height:28px;border:1px solid var(--nf-border);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;">3</div>
          <span style="font-family:var(--nf-heading-font);font-size:18px;font-weight:600;">Payment</span>
        </div>
        <div style="padding:24px;">
          <p style="font-size:14px;color:var(--nf-text-muted);">Payment options will appear here.</p>
          <button class="nf-btn nf-btn-primary nf-btn-full" style="margin-top:20px;" id="button-confirm">Place Order</button>
        </div>
      </div>
    </div>
    <div class="nf-cart-summary">
      <h2 class="nf-cart-summary-title">Your Order</h2>
      {% if products %}{% for product in products %}
      <div style="display:flex;gap:12px;padding:12px 0;border-bottom:1px solid var(--nf-border);">
        <img src="{{ product.thumb }}" alt="{{ product.name }}" style="width:64px;height:80px;object-fit:cover;border:1px solid var(--nf-border);flex-shrink:0;">
        <div style="flex:1;"><div style="font-size:13px;font-weight:500;margin-bottom:4px;">{{ product.name }}</div><div style="font-size:12px;color:var(--nf-text-muted);">×{{ product.quantity }}</div></div>
        <div style="font-size:13px;font-weight:600;flex-shrink:0;">{{ product.price }}</div>
      </div>
      {% endfor %}{% endif %}
      {% if totals %}{% for total in totals %}<div class="nf-cart-total-row"><span>{{ total.title }}</span><span>{{ total.text }}</span></div>{% endfor %}{% endif %}
    </div>
  </div>
</div>
{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
