{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}

{# Hero Banner #}
{% if nf_enable_hero %}
<section class="nf-hero">
  <div class="nf-hero-bg"></div>
  <div class="nf-hero-content">
    <div class="nf-hero-eyebrow">New Season · SS 2025</div>
    <h1 class="nf-hero-title">Dress for<br>the Moment</h1>
    <p class="nf-hero-subtitle">Discover our curated collection of contemporary fashion for every occasion.</p>
    <div style="display:flex;gap:12px;flex-wrap:wrap;">
      <a href="index.php?route=product/category" class="nf-btn nf-btn-gold">Shop Collection</a>
      <a href="index.php?route=product/special" class="nf-btn nf-btn-outline-white">View Sale</a>
    </div>
  </div>
</section>
{% endif %}

{# Lookbook Grid #}
{% if nf_enable_lookbook %}
<section style="padding:4px 0;">
  <div class="nf-lookbook">
    {% for i in 1..4 %}
    <a href="{{ home }}" class="nf-lookbook-item">
      <div style="width:100%;height:100%;background:{% if i == 1 %}#2a2a2a{% elseif i == 2 %}#3a3a3a{% elseif i == 3 %}#4a4a4a{% else %}#1e1e1e{% endif %};display:flex;align-items:center;justify-content:center;">
        <span style="font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3);">Lookbook {{ i }}</span>
      </div>
      <div class="nf-lookbook-overlay">
        <div class="nf-lookbook-title">Shop the Look</div>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

{# Category Grid #}
{% if nf_enable_catgrid and categories %}
<section class="nf-section">
  <div class="nf-container">
    <div class="nf-section-header">
      <div class="nf-section-eyebrow">Browse</div>
      <h2 class="nf-section-title">Shop by Category</h2>
    </div>
    <div class="nf-cat-grid">
      {% for cat in categories|slice(0, 4) %}
      <a href="{{ cat.href }}" class="nf-cat-item">
        <div style="position:absolute;inset:0;background:#2a2a2a;"></div>
        <div class="nf-cat-label">
          <div class="nf-cat-label-title">{{ cat.name }}</div>
          <div class="nf-cat-label-count">Explore →</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# Featured Products #}
{% if nf_enable_featured and products %}
<section class="nf-section" style="background:var(--nf-surface);">
  <div class="nf-container">
    <div class="nf-section-header">
      <div class="nf-section-eyebrow">Curated Picks</div>
      <h2 class="nf-section-title">New Arrivals</h2>
      <p class="nf-section-subtitle">Fresh pieces from this season's most sought-after collections.</p>
    </div>
    <div class="nf-product-grid">
      {% for product in products %}
      <div class="nf-card">
        <a href="{{ product.href }}" class="nf-card-image">
          <img src="{{ product.thumb }}" alt="{{ product.name }}" loading="{{ loop.index <= 4 ? 'eager' : 'lazy' }}">
          {% if product.special %}<span class="nf-card-badge">Sale</span>{% endif %}
          <div class="nf-card-actions">
            <button class="nf-card-action" data-nf-add-to-cart data-product-id="{{ product.product_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/></svg>
              Add to Cart
            </button>
            <button class="nf-card-action nf-card-action-wish" data-nf-wishlist data-product-id="{{ product.product_id }}" aria-label="Wishlist">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
          </div>
        </a>
        <div class="nf-card-body">
          <a href="{{ product.href }}" class="nf-card-name">{{ product.name }}</a>
          <div class="nf-card-price">
            {% if product.special %}
              <span class="nf-price nf-price-sale">{{ product.special }}</span>
              <span class="nf-price-old">{{ product.price }}</span>
            {% else %}
              <span class="nf-price">{{ product.price }}</span>
            {% endif %}
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
    <div style="text-align:center;margin-top:48px;">
      <a href="index.php?route=product/category" class="nf-btn nf-btn-outline">View All Products</a>
    </div>
  </div>
</section>
{% endif %}

{# Instagram Grid placeholder #}
{% if nf_enable_instagram %}
<section class="nf-section" style="padding-bottom:0;">
  <div class="nf-container">
    <div class="nf-section-header">
      <div class="nf-section-eyebrow">@{{ store|lower|replace({' ':''}) }}</div>
      <h2 class="nf-section-title">Shop the Gram</h2>
    </div>
  </div>
  <div class="nf-instagram">
    {% for i in 1..6 %}
    <a href="#" class="nf-instagram-item">
      <div style="width:100%;height:100%;background:{% if i is odd %}#2a2a2a{% else %}#1e1e1e{% endif %};display:flex;align-items:center;justify-content:center;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
      </div>
    </a>
    {% endfor %}
  </div>
</section>
{% endif %}

{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
