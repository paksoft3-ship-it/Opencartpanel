{% if breadcrumbs %}
<nav class="nf-breadcrumb" aria-label="Breadcrumb">
  <div class="nf-container">
    <ol class="nf-breadcrumb-list">
      {% for breadcrumb in breadcrumbs %}
      <li {% if loop.last %}aria-current="page"{% endif %}>
        {% if not loop.last %}<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>{% else %}{{ breadcrumb.text }}{% endif %}
      </li>
      {% endfor %}
    </ol>
  </div>
</nav>
{% endif %}
