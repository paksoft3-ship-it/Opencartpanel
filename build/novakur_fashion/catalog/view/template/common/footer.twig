      <div>
        <div class="nf-footer-brand-name">{{ store }}</div>
        <p class="nf-footer-brand-desc">Curated fashion for the discerning shopper. Quality over quantity, always.</p>
      </div>
      <div>
        <div class="nf-footer-col-title">Shop</div>
        <ul class="nf-footer-links">
          <li><a href="{{ home }}">Home</a></li>
          <li><a href="index.php?route=product/special">Sale</a></li>
          <li><a href="index.php?route=product/search">Search</a></li>
          <li><a href="index.php?route=manufacturer/list">Brands</a></li>
        </ul>
      </div>
      <div>
        <div class="nf-footer-col-title">Account</div>
        <ul class="nf-footer-links">
          <li><a href="{{ account|default('index.php?route=account/account') }}">My Account</a></li>
          <li><a href="{{ wishlists|default('index.php?route=account/wishlist') }}">Wishlist</a></li>
          <li><a href="index.php?route=account/order">Orders</a></li>
          <li><a href="{{ cart|default('index.php?route=checkout/cart') }}">Cart</a></li>
        </ul>
      </div>
