{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_fashion/catalog/view/template/common/breadcrumb.twig' %}
<div class="nf-container" style="padding:48px 32px;">
  <h1 style="font-family:var(--nf-heading-font);font-size:32px;font-weight:700;margin-bottom:32px;">Order History</h1>
  {% if orders %}
  <table style="width:100%;border-collapse:collapse;">
    <thead><tr>
      <th style="text-align:left;padding:10px 0;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Order #</th>
      <th style="text-align:left;padding:10px 0;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Date</th>
      <th style="text-align:left;padding:10px 0;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Status</th>
      <th style="text-align:right;padding:10px 0;font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Total</th>
      <th style="border-bottom:1px solid var(--nf-border);"></th>
    </tr></thead>
    <tbody>{% for order in orders %}
    <tr>
      <td style="padding:20px 0;border-bottom:1px solid var(--nf-border);font-weight:600;font-size:14px;">#{{ order.order_id }}</td>
      <td style="padding:20px 0;border-bottom:1px solid var(--nf-border);font-size:14px;color:var(--nf-text-muted);">{{ order.date_added }}</td>
      <td style="padding:20px 0;border-bottom:1px solid var(--nf-border);"><span style="font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;background:var(--nf-surface);padding:4px 10px;border:1px solid var(--nf-border);">{{ order.status }}</span></td>
      <td style="padding:20px 0;border-bottom:1px solid var(--nf-border);text-align:right;font-weight:600;font-size:14px;">{{ order.total }}</td>
      <td style="padding:20px 0;border-bottom:1px solid var(--nf-border);"><a href="{{ order.view }}" class="nf-btn nf-btn-ghost nf-btn-sm">View</a></td>
    </tr>
    {% endfor %}</tbody>
  </table>
  {% if pagination %}<div class="nf-pagination">{{ pagination }}</div>{% endif %}
  {% else %}
  <p style="color:var(--nf-text-muted);">No orders yet. <a href="{{ continue|default('index.php?route=common/home') }}" style="text-decoration:underline;color:var(--nf-text);">Start shopping</a></p>
  {% endif %}
</div>
{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
