{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_fashion/catalog/view/template/common/breadcrumb.twig' %}
<div class="nf-container">
  <div style="max-width:560px;margin:60px auto;">
    <h1 style="font-family:var(--nf-heading-font);font-size:32px;font-weight:700;margin-bottom:32px;">{% if address_id is defined and address_id %}Edit{% else %}New{% endif %} Address</h1>
    <form action="{{ action }}" method="post">
      <div class="nf-form-row"><div class="nf-form-group"><label>First Name *</label><input type="text" name="firstname" value="{{ firstname|default('') }}" required></div><div class="nf-form-group"><label>Last Name *</label><input type="text" name="lastname" value="{{ lastname|default('') }}" required></div></div>
      <div class="nf-form-group"><label>Company</label><input type="text" name="company" value="{{ company|default('') }}"></div>
      <div class="nf-form-group"><label>Address 1 *</label><input type="text" name="address_1" value="{{ address_1|default('') }}" required></div>
      <div class="nf-form-group"><label>Address 2</label><input type="text" name="address_2" value="{{ address_2|default('') }}"></div>
      <div class="nf-form-row"><div class="nf-form-group"><label>City *</label><input type="text" name="city" value="{{ city|default('') }}" required></div><div class="nf-form-group"><label>Postcode *</label><input type="text" name="postcode" value="{{ postcode|default('') }}" required></div></div>
      <div class="nf-form-group"><label>Country *</label><select name="country_id" class="nf-option-select">{% if countries is defined %}{% for country in countries %}<option value="{{ country.country_id }}" {% if country.country_id == country_id %}selected{% endif %}>{{ country.name }}</option>{% endfor %}{% endif %}</select></div>
      <div class="nf-form-group"><label>Region *</label><select name="zone_id" class="nf-option-select">{% if zones is defined %}{% for zone in zones %}<option value="{{ zone.zone_id }}" {% if zone.zone_id == zone_id %}selected{% endif %}>{{ zone.name }}</option>{% endfor %}{% endif %}</select></div>
      <div style="display:flex;gap:12px;margin-top:8px;"><button type="submit" class="nf-btn nf-btn-primary">Save Address</button><a href="{{ back|default('index.php?route=account/address') }}" class="nf-btn nf-btn-ghost">Cancel</a></div>
    </form>
  </div>
</div>
{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
