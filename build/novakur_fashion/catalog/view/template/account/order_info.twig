{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_fashion/catalog/view/template/common/breadcrumb.twig' %}
<div class="nf-container" style="padding:48px 32px;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:32px;">
    <h1 style="font-family:var(--nf-heading-font);font-size:32px;font-weight:700;">Order #{{ order_id }}</h1>
    <a href="{{ back|default('index.php?route=account/order') }}" class="nf-btn nf-btn-ghost">← Back</a>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:32px;">
    <div><h3 style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-secondary);margin-bottom:12px;">Billing Address</h3><p style="font-size:14px;color:var(--nf-text-muted);line-height:1.8;">{{ payment_address }}</p></div>
    {% if shipping_address %}<div><h3 style="font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-secondary);margin-bottom:12px;">Shipping Address</h3><p style="font-size:14px;color:var(--nf-text-muted);line-height:1.8;">{{ shipping_address }}</p></div>{% endif %}
  </div>
  {% if products %}<table style="width:100%;border-collapse:collapse;margin-bottom:24px;"><thead><tr><th style="text-align:left;padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Product</th><th style="text-align:left;padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Model</th><th style="padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Qty</th><th style="text-align:right;padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Price</th><th style="text-align:right;padding:8px 0;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--nf-text-muted);border-bottom:1px solid var(--nf-border);">Total</th></tr></thead><tbody>{% for product in products %}<tr><td style="padding:16px 0;border-bottom:1px solid var(--nf-border);font-size:14px;">{{ product.name }}</td><td style="padding:16px 0;border-bottom:1px solid var(--nf-border);font-size:13px;color:var(--nf-text-muted);">{{ product.model }}</td><td style="padding:16px 0;border-bottom:1px solid var(--nf-border);font-size:14px;">{{ product.quantity }}</td><td style="padding:16px 0;border-bottom:1px solid var(--nf-border);text-align:right;font-size:14px;">{{ product.price }}</td><td style="padding:16px 0;border-bottom:1px solid var(--nf-border);text-align:right;font-size:14px;font-weight:600;">{{ product.total }}</td></tr>{% endfor %}</tbody></table>{% endif %}
  {% if totals %}<div style="max-width:320px;margin-left:auto;">{% for total in totals %}<div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--nf-border);font-size:14px;{% if loop.last %}font-weight:700;font-size:16px;{% endif %}"><span>{{ total.title }}</span><span>{{ total.text }}</span></div>{% endfor %}</div>{% endif %}
</div>
{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
