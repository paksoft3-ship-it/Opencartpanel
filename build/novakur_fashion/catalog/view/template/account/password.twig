{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_fashion/catalog/view/template/common/breadcrumb.twig' %}
<div class="nf-container">
  <div style="max-width:440px;margin:60px auto;">
    <h1 style="font-family:var(--nf-heading-font);font-size:32px;font-weight:700;margin-bottom:32px;">Change Password</h1>
    <form action="{{ action }}" method="post">
      <div class="nf-form-group"><label>New Password *</label><input type="password" name="password" required></div>
      <div class="nf-form-group"><label>Confirm Password *</label><input type="password" name="confirm" required></div>
      <div style="display:flex;gap:12px;margin-top:8px;">
        <button type="submit" class="nf-btn nf-btn-primary">Update Password</button>
        <a href="{{ back|default('index.php?route=account/account') }}" class="nf-btn nf-btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
