{% include 'extension/novakur_fashion/catalog/view/template/common/header.twig' %}
{% include 'extension/novakur_fashion/catalog/view/template/common/breadcrumb.twig' %}
<div class="nf-container" style="padding:48px 32px;">
  <h1 style="font-family:var(--nf-heading-font);font-size:36px;font-weight:700;margin-bottom:32px;">Search</h1>
  <form action="{{ action_search|default('index.php?route=product/search') }}" method="get" style="max-width:480px;margin-bottom:48px;">
    <div style="display:flex;gap:8px;">
      <input type="text" name="search" value="{{ search|default(keyword|default('')) }}" placeholder="Search products, brands…" style="flex:1;height:48px;padding:0 16px;border:1px solid var(--nf-border);font-size:14px;font-family:inherit;outline:none;background:transparent;">
      <button type="submit" class="nf-btn nf-btn-primary">Search</button>
    </div>
  </form>
  {% if products %}
  <p style="font-size:12px;color:var(--nf-text-muted);letter-spacing:0.06em;margin-bottom:24px;">{{ results }}</p>
  <div class="nf-product-grid">{% for product in products %}<div class="nf-card"><a href="{{ product.href }}" class="nf-card-image"><img src="{{ product.thumb }}" alt="{{ product.name }}" loading="lazy">{% if product.special %}<span class="nf-card-badge">Sale</span>{% endif %}</a><div class="nf-card-body"><a href="{{ product.href }}" class="nf-card-name">{{ product.name }}</a><div class="nf-card-price">{% if product.special %}<span class="nf-price nf-price-sale">{{ product.special }}</span><span class="nf-price-old">{{ product.price }}</span>{% else %}<span class="nf-price">{{ product.price }}</span>{% endif %}</div></div></div>{% endfor %}</div>
  {% if pagination %}<div class="nf-pagination">{{ pagination }}</div>{% endif %}
  {% elseif search is defined or keyword is defined %}
  <div style="text-align:center;padding:80px 0;"><p style="font-family:var(--nf-heading-font);font-size:24px;color:var(--nf-text-muted);">No results found.</p></div>
  {% endif %}
</div>
{% include 'extension/novakur_fashion/catalog/view/template/common/footer.twig' %}
